# Copy this file to .env.selfhost.local for a Docker rehearsal.
# Keep .env.selfhost.local private; it is ignored by git.

# For Supabase CLI local development this is usually http://127.0.0.1:54321.
# For self-hosted Supabase Docker it is often your Kong/API origin, such as:
# http://localhost:8000 or https://sb.changzhouai.club.
# If the Next.js app also runs in Docker, use a URL reachable by both the
# browser and the container. A LAN IP or rehearsal domain is safer than localhost.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Required for admin-side uploads and migration scripts.
SUPABASE_SERVICE_ROLE_KEY=

# Optional WeChat Open Platform website login.
# Use the auth callback domain, for example: https://auth.changzhouai.club.
WECHAT_OPEN_APP_ID=
WECHAT_OPEN_APP_SECRET=
WECHAT_OAUTH_BASE_URL=

# Use the URL users open in the browser during rehearsal.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
SITE_URL=http://localhost:3000

# Self-hosted runs should keep Vercel-only analytics disabled.
ENABLE_VERCEL_INSIGHTS=false

# Optional self-hosted Umami analytics.
# Example: https://analytics.example.com/script.js
NEXT_PUBLIC_UMAMI_SCRIPT_URL=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
# Comma-separated hostnames to avoid collecting localhost/staging traffic.
NEXT_PUBLIC_UMAMI_DOMAINS=

# Optional notification channels.
RESEND_API_KEY=
ADMIN_NOTIFICATION_EMAIL=
ADMIN_NOTIFICATION_EMAILS=
ADMIN_NOTIFICATION_FROM_EMAIL="Changzhou AI Club <onboarding@example.com>"
ADMIN_NOTIFICATION_WECOM_WEBHOOK=
WECOM_BOT_WEBHOOK_URL=
ADMIN_NOTIFICATION_FEISHU_WEBHOOK=
FEISHU_BOT_WEBHOOK_URL=
ADMIN_NOTIFICATION_FEISHU_SECRET=
FEISHU_BOT_WEBHOOK_SECRET=
