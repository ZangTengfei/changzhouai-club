.registrations-page {
  padding-top: 28rpx;
}

.registration-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.registration-card {
  overflow: hidden;
}

.registration-cover {
  display: flex;
  width: 100%;
  height: 280rpx;
  align-items: center;
  justify-content: center;
  background: #edf1ef;
}

.registration-placeholder image {
  width: 120rpx;
  height: 120rpx;
}

.registration-content {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 26rpx;
}

.registration-meta,
.registration-footer {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.registration-meta {
  justify-content: space-between;
  color: var(--color-subtle);
  font-size: 23rpx;
}

.status {
  padding: 5rpx 14rpx;
  border-radius: 18rpx;
  background: var(--color-green-soft);
  color: var(--color-green-dark);
  font-size: 21rpx;
  font-weight: 720;
}

.status-waitlisted {
  background: var(--color-yellow-soft);
  color: #8d6810;
}

.status-cancelled {
  background: #f1f3f2;
  color: var(--color-subtle);
}

.registration-title {
  font-size: 32rpx;
  font-weight: 810;
  line-height: 1.4;
}

.registration-footer {
  min-height: 46rpx;
}

.registration-location {
  overflow: hidden;
  flex: 1;
  color: var(--color-subtle);
  font-size: 23rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}
