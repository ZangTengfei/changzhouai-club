<view class="page-shell settings-page">
  <view wx:if="{{loading}}" class="empty-state">正在加载设置</view>
  <view wx:elif="{{loadFailed}}" class="empty-state" bindtap="loadSettings">设置加载失败，轻触重试</view>

  <block wx:else>
    <view class="settings-identity"><text class="settings-caption">社区账号</text><text class="settings-name">{{displayName}}</text><text class="settings-summary">管理资料、账号连接与隐私选项。</text></view>

    <view class="settings-group">
      <text class="settings-group-title">个人信息</text>
      <view class="settings-list">
        <view class="settings-row" bindtap="openProfile" role="button">
          <image class="settings-icon" src="/assets/icons/profile-blue-v2.png" mode="aspectFit" />
          <text class="settings-label">编辑资料</text>
          <image class="settings-arrow" src="/assets/icons/chevron-soft-v2.png" mode="aspectFit" />
        </view>
        <view class="settings-row" bindtap="openPrivacy" role="button">
          <image class="settings-icon" src="/assets/icons/privacy-green-v2.png" mode="aspectFit" />
          <text class="settings-label">隐私说明</text>
          <image class="settings-arrow" src="/assets/icons/chevron-soft-v2.png" mode="aspectFit" />
        </view>
      </view>
    </view>

    <view class="settings-group">
      <view class="settings-group-heading"><text class="settings-group-title">账号连接</text><text class="settings-count">{{linkedChannels.length}} 项</text></view>
      <view class="settings-list">
        <view wx:for="{{linkedChannels}}" wx:key="*this" class="settings-row connection-row">
          <image class="settings-icon" src="/assets/icons/link-purple-v2.png" mode="aspectFit" />
          <text class="settings-label">{{item}}</text>
          <text class="connection-status">已连接</text>
        </view>
      </view>
    </view>

    <button class="logout-button" loading="{{submitting}}" disabled="{{submitting}}" bindtap="handleLogout">
      <image src="/assets/icons/logout-orange-v2.png" mode="aspectFit" />
      <text>退出当前账号</text>
    </button>
  </block>
</view>
