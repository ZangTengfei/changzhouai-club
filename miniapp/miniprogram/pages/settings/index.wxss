.settings-page {
  padding-top: 26rpx;
}

.settings-identity {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 30rpx;
  border: 2rpx solid #dcefe5;
  border-radius: var(--radius-card);
  background: var(--color-green-soft);
}

.settings-caption {
  color: var(--color-green-dark);
  font-size: 22rpx;
  font-weight: 720;
}

.settings-name {
  font-size: 40rpx;
  font-weight: 830;
}

.settings-summary {
  color: var(--color-subtle);
  font-size: 23rpx;
  line-height: 1.5;
}

.settings-group {
  margin-top: 30rpx;
}

.settings-group-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.settings-group-title {
  display: block;
  margin-bottom: 16rpx;
  font-size: 27rpx;
  font-weight: 790;
}

.settings-count {
  margin-bottom: 16rpx;
  color: var(--color-subtle);
  font-size: 22rpx;
}

.settings-list {
  overflow: hidden;
  border: 2rpx solid var(--color-line);
  border-radius: var(--radius-card);
  background: #ffffff;
  box-shadow: var(--shadow-card);
}

.settings-row {
  display: flex;
  min-height: 106rpx;
  align-items: center;
  gap: 18rpx;
  padding: 0 24rpx;
  border-bottom: 2rpx solid var(--color-line);
}

.settings-row:last-child {
  border-bottom: 0;
}

.settings-icon {
  box-sizing: border-box;
  width: 64rpx;
  height: 64rpx;
  flex: 0 0 auto;
  padding: 14rpx;
  border-radius: 20rpx;
  background: var(--color-blue-soft);
}

.connection-row .settings-icon {
  background: var(--color-purple-soft);
}

.settings-label {
  min-width: 0;
  flex: 1;
  font-size: 27rpx;
  font-weight: 680;
}

.settings-arrow {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.7;
}

.connection-status {
  padding: 5rpx 13rpx;
  border-radius: 18rpx;
  background: var(--color-green-soft);
  color: var(--color-green-dark);
  font-size: 21rpx;
  font-weight: 700;
}

.logout-button {
  display: flex;
  width: 100%;
  min-height: 92rpx;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-top: 42rpx;
  border: 2rpx solid #ffd9d2;
  border-radius: 46rpx;
  background: #fff3f0;
  color: #bf3e2e;
  font-size: 27rpx;
  font-weight: 700;
}

.logout-button::after {
  border: 0;
}

.logout-button image {
  width: 34rpx;
  height: 34rpx;
}
