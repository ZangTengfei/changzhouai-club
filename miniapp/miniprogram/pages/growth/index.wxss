.growth-page {
  padding-top: 24rpx;
}

.growth-intro {
  margin-bottom: 22rpx;
  color: var(--color-subtle);
  font-size: 26rpx;
  line-height: 1.55;
}

.growth-identity {
  display: flex;
  align-items: center;
  gap: 28rpx;
  padding: 32rpx;
  border: 2rpx solid #dcefe5;
  border-radius: 36rpx;
  background: var(--color-green-soft);
}

.level-badge {
  width: 150rpx;
  height: 150rpx;
  flex: 0 0 auto;
}

.growth-identity-copy {
  display: flex;
  min-width: 0;
  flex: 1;
  flex-direction: column;
  gap: 8rpx;
}

.growth-kicker {
  color: var(--color-green-dark);
  font-size: 22rpx;
  font-weight: 720;
}

.growth-level {
  font-size: 40rpx;
  font-weight: 830;
  line-height: 1.25;
}

.growth-member {
  color: var(--color-subtle);
  font-size: 23rpx;
  line-height: 1.5;
}

.growth-stats {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  margin-top: 22rpx;
  padding: 26rpx 10rpx;
  border: 2rpx solid var(--color-line);
  border-radius: var(--radius-card);
  background: #ffffff;
  box-shadow: var(--shadow-card);
}

.stat-item {
  display: flex;
  min-width: 0;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  border-right: 2rpx solid var(--color-line);
}

.stat-item:last-child {
  border-right: 0;
}

.stat-value {
  font-size: 38rpx;
  font-weight: 830;
}

.stat-label {
  color: var(--color-subtle);
  font-size: 21rpx;
}

.growth-section {
  margin-top: 30rpx;
  padding: 28rpx;
  border: 2rpx solid var(--color-line);
  border-radius: var(--radius-card);
  background: #ffffff;
}

.growth-section:nth-of-type(4) {
  border-color: #f1e3ac;
  background: var(--color-yellow-soft);
}

.section-heading {
  display: flex;
  flex-direction: column;
  gap: 7rpx;
  margin-bottom: 24rpx;
}

.section-note {
  color: var(--color-subtle);
  font-size: 22rpx;
}

.growth-path,
.honor-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.growth-step {
  display: grid;
  grid-template-columns: 60rpx minmax(0, 1fr) auto;
  align-items: center;
  gap: 16rpx;
  min-height: 116rpx;
  padding: 18rpx;
  border: 2rpx solid #e4ece8;
  border-radius: 24rpx;
  background: #f8faf9;
}

.growth-step-complete {
  border-color: #d4ecdf;
  background: var(--color-green-soft);
}

.growth-step-current {
  border-color: #c9e0ff;
  background: var(--color-blue-soft);
}

.growth-step-index {
  display: flex;
  width: 56rpx;
  height: 56rpx;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #ffffff;
  color: var(--color-green-dark);
  font-size: 24rpx;
  font-weight: 780;
}

.growth-step-copy {
  display: flex;
  min-width: 0;
  flex-direction: column;
  gap: 5rpx;
}

.growth-step-label {
  font-size: 27rpx;
  font-weight: 780;
}

.growth-step-description {
  color: var(--color-subtle);
  font-size: 21rpx;
  line-height: 1.45;
}

.growth-step-state {
  color: var(--color-green-dark);
  font-size: 20rpx;
  font-weight: 700;
  white-space: nowrap;
}

.honor-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.76);
}

.honor-row image {
  width: 62rpx;
  height: 62rpx;
  flex: 0 0 auto;
}

.honor-copy {
  display: flex;
  min-width: 0;
  flex-direction: column;
  gap: 5rpx;
}

.honor-name {
  font-size: 27rpx;
  font-weight: 780;
}

.honor-description,
.honor-empty {
  color: var(--color-muted);
  font-size: 22rpx;
  line-height: 1.5;
}

.honor-empty {
  padding: 24rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.7);
}
