.news-page {
  padding-top: 18rpx;
}

.page-intro {
  margin-bottom: 22rpx;
}

.category-scroll {
  width: 100%;
  margin-bottom: 18rpx;
}

.stale-note {
  margin-bottom: 20rpx;
  padding: 20rpx 24rpx;
  border-radius: 22rpx;
  background: var(--color-yellow-soft);
  color: #8d6810;
  font-size: 23rpx;
  line-height: 1.5;
}

.hot-heading,
.news-heading,
.digest-heading {
  margin-top: 34rpx;
}

.hot-source,
.news-count {
  color: var(--color-subtle);
  font-size: 24rpx;
}

.hot-area {
  display: flex;
  flex-direction: column;
}

.hot-topic-card {
  display: flex;
  min-height: 290rpx;
  align-items: stretch;
  gap: 12rpx;
  margin-bottom: 16rpx;
  padding: 30rpx;
  overflow: hidden;
  border: 2rpx solid #d4e8ff;
  border-radius: var(--radius-card);
  background: var(--color-blue-soft);
}

.hot-topic-card:not(:first-child) {
  min-height: 176rpx;
}

.hot-topic-copy {
  display: flex;
  min-width: 0;
  flex: 1;
  flex-direction: column;
  justify-content: center;
  gap: 12rpx;
}

.hot-topic-label {
  color: var(--color-blue);
  font-size: 22rpx;
  font-weight: 760;
}

.hot-topic-title {
  display: -webkit-box;
  overflow: hidden;
  font-size: 34rpx;
  font-weight: 820;
  line-height: 1.35;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.hot-topic-meta {
  color: var(--color-subtle);
  font-size: 23rpx;
}

.hot-topic-action {
  margin-top: 12rpx;
  color: var(--color-green-dark);
  font-size: 25rpx;
  font-weight: 720;
}

.hot-topic-visual {
  display: flex;
  width: 142rpx;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  opacity: 0.72;
}

.hot-topic-visual image {
  width: 100rpx;
  height: 100rpx;
}

.news-list,
.digest-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.news-card {
  display: flex;
  min-height: 150rpx;
  align-items: center;
  gap: 18rpx;
  padding: 24rpx;
  border: 2rpx solid #dcefe5;
  border-radius: 28rpx;
  background: var(--color-green-soft);
}

.news-card:nth-child(3n + 2) {
  border-color: #ffe2c7;
  background: var(--color-orange-soft);
}

.news-card:nth-child(3n) {
  border-color: #e3ddff;
  background: var(--color-purple-soft);
}

.news-card-icon {
  display: flex;
  width: 76rpx;
  height: 76rpx;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.78);
}

.news-card-icon image {
  width: 40rpx;
  height: 40rpx;
}

.news-card-copy {
  display: flex;
  min-width: 0;
  flex: 1;
  flex-direction: column;
  gap: 7rpx;
}

.news-card-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  color: var(--color-green-dark);
  font-size: 20rpx;
  font-weight: 700;
}

.news-card-title {
  display: -webkit-box;
  overflow: hidden;
  font-size: 28rpx;
  font-weight: 790;
  line-height: 1.4;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.news-card-summary,
.news-card-reason {
  display: -webkit-box;
  overflow: hidden;
  color: var(--color-muted);
  font-size: 22rpx;
  line-height: 1.5;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.news-card-reason {
  color: var(--color-green-dark);
  font-weight: 650;
}

.digest-card {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 28rpx;
  border: 2rpx solid #e3ddff;
  border-radius: var(--radius-card);
  background: var(--color-purple-soft);
}

.digest-card:nth-child(2n) {
  border-color: #dcefe5;
  background: var(--color-green-soft);
}

.digest-card-top,
.digest-footer {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.digest-date,
.digest-favorite {
  color: var(--color-purple);
  font-size: 21rpx;
  font-weight: 720;
}

.digest-title {
  font-size: 31rpx;
  font-weight: 800;
  line-height: 1.4;
}

.digest-summary {
  display: -webkit-box;
  overflow: hidden;
  color: var(--color-muted);
  font-size: 23rpx;
  line-height: 1.58;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
}

.digest-footer {
  min-height: 60rpx;
  color: var(--color-subtle);
  font-size: 21rpx;
}

.digest-footer image {
  margin-left: auto;
}

.loading-more {
  padding: 30rpx 0 8rpx;
  color: var(--color-subtle);
  font-size: 23rpx;
  text-align: center;
}
