<view class="page-shell detail-page">
  <view wx:if="{{loading}}" class="empty-state">正在打开内容</view>
  <view wx:elif="{{loadFailed}}" class="empty-state" bindtap="loadDetail">内容暂时不可用，轻触重试</view>

  <block wx:elif="{{kind === 'news' && news}}">
    <view class="detail-eyebrow"><text>{{news.categoryLabel}}</text><text>{{news.sourceName}}</text></view>
    <text class="detail-title">{{news.title}}</text>
    <text wx:if="{{news.summary}}" class="detail-lead">{{news.summary}}</text>
    <view wx:if="{{news.recommendationReason}}" class="reason-panel"><text>推荐理由</text><text>{{news.recommendationReason}}</text></view>
    <view class="detail-actions">
      <button class="action-button {{news.isFavorited ? 'action-button-active' : ''}}" bindtap="toggleFavorite" loading="{{savingFavorite}}">{{news.isFavorited ? '已收藏' : '收藏'}}</button>
      <button wx:if="{{news.sourceUrl}}" class="action-button" data-url="{{news.sourceUrl}}" bindtap="copySource">复制原文链接</button>
    </view>
    <view class="source-note"><text>来源</text><text>{{news.sourceName}}</text><text>原文链接将复制到剪贴板，可在微信内打开。</text></view>
  </block>

  <block wx:elif="{{kind === 'digest' && digest}}">
    <view class="detail-eyebrow"><text>群聊精华</text><text>{{digest.date}}</text></view>
    <text class="detail-title">{{digest.title}}</text>
    <text wx:if="{{digest.overview}}" class="detail-lead">{{digest.overview}}</text>
    <view class="detail-actions"><button class="action-button {{digest.isFavorited ? 'action-button-active' : ''}}" bindtap="toggleFavorite" loading="{{savingFavorite}}">{{digest.isFavorited ? '已收藏' : '收藏'}}</button></view>

    <view wx:if="{{digest.highlights.length}}" class="detail-section"><text class="detail-section-label">今日重点</text><text class="detail-section-title">讨论要点</text><view class="detail-list"><view wx:for="{{digest.highlights}}" wx:key="title" class="detail-item"><text class="detail-item-title">{{item.title}}</text><text class="detail-item-copy">{{item.summary}}</text></view></view></view>
    <view wx:if="{{digest.discussions.length}}" class="detail-section"><text class="detail-section-label">重点讨论</text><text class="detail-section-title">形成了哪些判断</text><view class="detail-list"><view wx:for="{{digest.discussions}}" wx:key="title" class="detail-item"><text class="detail-item-title">{{item.title}}</text><text class="detail-item-copy">{{item.conclusion}}</text></view></view></view>
    <view wx:if="{{digest.resources.length}}" class="detail-section"><text class="detail-section-label">资源线索</text><text class="detail-section-title">继续深入</text><view class="detail-list"><view wx:for="{{digest.resources}}" wx:key="title" class="detail-item"><text class="detail-item-title">{{item.title}}</text><text class="detail-item-copy">{{item.body}}</text><text wx:if="{{item.url}}" class="detail-link" data-url="{{item.url}}" bindtap="copySource">复制资源链接</text></view></view></view>
    <view wx:if="{{digest.tags.length}}" class="tag-list"><text wx:for="{{digest.tags}}" wx:key="*this"># {{item}}</text></view>
    <text class="privacy-note">本页内容由网站群聊日报同步并经过脱敏，不包含原始聊天记录、成员列表或联系方式。</text>
  </block>
</view>
