<custom-navigation title="今日情报" />

<view class="page-shell news-page">
  <view class="page-intro">
    <text class="page-intro-copy">从噪音里，找到真正重要的事。</text>
  </view>

  <view class="segmented-control" aria-label="内容类型">
    <view class="segmented-item {{activeSection === 'selected' ? 'segmented-item-active' : ''}}" data-section="selected" bindtap="switchSection">精选</view>
    <view class="segmented-item {{activeSection === 'all' ? 'segmented-item-active' : ''}}" data-section="all" bindtap="switchSection">AI 快讯</view>
    <view class="segmented-item {{activeSection === 'digest' ? 'segmented-item-active' : ''}}" data-section="digest" bindtap="switchSection">群聊精华</view>
  </view>

  <scroll-view wx:if="{{activeSection !== 'digest'}}" class="category-scroll" scroll-x="true" enable-flex="true" aria-label="资讯分类">
    <view class="chip-row">
      <view wx:for="{{categories}}" wx:key="id" class="filter-chip {{activeCategory === item.id ? 'filter-chip-active' : ''}}" data-category="{{item.id}}" bindtap="switchCategory">{{item.label}}</view>
    </view>
  </scroll-view>

  <view wx:if="{{isStale && !loading}}" class="stale-note">外部内容源暂时波动，正在展示最近一次整理结果。</view>
  <view wx:if="{{loading}}" class="empty-state">正在整理今日内容</view>
  <view wx:elif="{{loadFailed}}" class="empty-state" bindtap="loadContent">内容加载失败，轻触重试</view>

  <block wx:elif="{{activeSection !== 'digest'}}">
    <view wx:if="{{activeSection === 'selected' && activeCategory === 'all' && hotTopics.length}}" class="hot-area">
      <view class="section-heading-row hot-heading">
        <text class="section-title">当前热点</text>
        <text class="hot-source">多源聚合</text>
      </view>
      <view wx:for="{{hotTopics}}" wx:key="id" class="hot-topic-card" data-id="{{item.id}}" bindtap="openNews">
        <view class="hot-topic-copy">
          <text class="hot-topic-label">HOT NOW · {{item.sourceCount}} 个信源</text>
          <text class="hot-topic-title">{{item.title}}</text>
          <text class="hot-topic-meta">{{item.sourceName}} · {{item.latestLabel}}</text>
          <text class="hot-topic-action">查看解读</text>
        </view>
        <view class="hot-topic-visual"><image src="/assets/icons/news-active.png" mode="aspectFit" /></view>
      </view>
    </view>

    <view class="section-heading-row news-heading">
      <text class="section-title">{{activeSection === 'selected' ? '今日精选' : 'AI 快讯'}}</text>
      <text class="news-count">{{items.length}} 条</text>
    </view>

    <view wx:if="{{items.length === 0}}" class="empty-state">这一类内容还在整理中</view>
    <view wx:else class="news-list">
      <view wx:for="{{items}}" wx:key="id" class="news-card" data-id="{{item.id}}" bindtap="openNews">
        <view class="news-card-icon"><image src="/assets/icons/news.png" mode="aspectFit" /></view>
        <view class="news-card-copy">
          <view class="news-card-meta"><text>{{item.categoryLabel}}</text><text>{{item.dateLabel}}</text><text wx:if="{{item.isFavorited}}">已收藏</text></view>
          <text class="news-card-title">{{item.title}}</text>
          <text wx:if="{{item.summary}}" class="news-card-summary">{{item.summary}}</text>
          <text wx:if="{{item.recommendationReason}}" class="news-card-reason">推荐 · {{item.recommendationReason}}</text>
        </view>
        <image class="row-arrow" src="/assets/icons/chevron-right.png" mode="aspectFit" />
      </view>
    </view>
    <view wx:if="{{loadingMore}}" class="loading-more">正在继续加载</view>
    <view wx:elif="{{hasNext}}" class="loading-more">继续下滑查看更多</view>
  </block>

  <block wx:else>
    <view class="section-heading-row digest-heading"><text class="section-title">最近整理</text><text class="news-count">{{digests.length}} 期</text></view>
    <view wx:if="{{digests.length === 0}}" class="empty-state">还没有可展示的群聊精华</view>
    <view wx:else class="digest-list">
      <view wx:for="{{digests}}" wx:key="id" class="digest-card" data-id="{{item.id}}" bindtap="openDigest">
        <view class="digest-card-top"><text class="digest-date">{{item.dateLabel}}</text><text wx:if="{{item.isFavorited}}" class="digest-favorite">已收藏</text></view>
        <text class="digest-title">{{item.title}}</text>
        <text class="digest-summary">{{item.summaryLabel}}</text>
        <view class="digest-footer"><text>{{item.highlightCount}} 个讨论要点</text><text>{{item.resourceCount}} 条资源线索</text><image class="row-arrow" src="/assets/icons/chevron-right.png" mode="aspectFit" /></view>
      </view>
    </view>
  </block>
</view>
