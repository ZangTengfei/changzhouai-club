.privacy-page {
  padding-top: 28rpx;
}

.privacy-hero {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 30rpx;
  border: 2rpx solid #dcefe5;
  border-radius: 36rpx;
  background: var(--color-green-soft);
}

.privacy-kicker,
.privacy-index {
  color: var(--color-green-dark);
  font-size: 22rpx;
  font-weight: 760;
}

.privacy-hero-title {
  font-size: 38rpx;
  font-weight: 820;
  line-height: 1.35;
}

.privacy-hero-copy {
  color: var(--color-muted);
  font-size: 24rpx;
  line-height: 1.6;
}

.privacy-section {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-top: 20rpx;
  padding: 28rpx;
  border: 2rpx solid rgba(17, 23, 21, 0.04);
  border-radius: 28rpx;
}

.privacy-section-green {
  background: var(--color-green-soft);
}

.privacy-section-blue {
  background: var(--color-blue-soft);
}

.privacy-section-purple {
  background: var(--color-purple-soft);
}

.privacy-section-orange {
  background: var(--color-orange-soft);
}

.privacy-title {
  font-size: 30rpx;
  font-weight: 800;
}

.privacy-copy {
  color: var(--color-muted);
  font-size: 25rpx;
  line-height: 1.75;
}

.privacy-version {
  display: block;
  padding: 34rpx 0 8rpx;
  color: var(--color-subtle);
  font-size: 22rpx;
  text-align: center;
}
