.profile-page {
  padding-top: 28rpx;
}

.profile-form {
  display: flex;
  flex-direction: column;
}

.form-heading {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 30rpx;
  border: 2rpx solid #dcefe5;
  border-radius: 34rpx;
  background: var(--color-green-soft);
}

.form-heading > view:first-child {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 20rpx;
}

.completion-label {
  color: var(--color-green-dark);
  font-size: 24rpx;
  font-weight: 720;
}

.form-summary {
  font-size: 24rpx;
  line-height: 1.6;
}

.completion-track {
  height: 12rpx;
  overflow: hidden;
  border-radius: 6rpx;
  background: #d6ecdf;
}

.completion-value {
  height: 100%;
  border-radius: 6rpx;
  background: var(--color-green);
}

.stepper {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 8rpx;
  margin-top: 22rpx;
  padding: 10rpx;
  border: 2rpx solid var(--color-line);
  border-radius: 30rpx;
  background: #ffffff;
}

.step-item {
  display: flex;
  min-width: 0;
  min-height: 82rpx;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  border-radius: 22rpx;
  color: var(--color-subtle);
}

.step-item-active {
  background: var(--color-green);
  color: #ffffff;
}

.step-item-complete {
  background: var(--color-green-soft);
  color: var(--color-green-dark);
}

.step-number {
  font-size: 21rpx;
  font-weight: 780;
}

.step-label {
  overflow: hidden;
  max-width: 100%;
  font-size: 20rpx;
  font-weight: 680;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.step-heading {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin: 34rpx 0 20rpx;
}

.step-title {
  font-size: 38rpx;
  font-weight: 820;
}

.step-hint {
  color: var(--color-subtle);
  font-size: 23rpx;
  line-height: 1.55;
}

.step-content {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.avatar-picker {
  display: flex;
  min-height: 150rpx;
  box-sizing: border-box;
  align-items: center;
  gap: 22rpx;
  margin: 0;
  padding: 22rpx;
  border: 2rpx solid #dcefe5;
  border-radius: 28rpx;
  background: var(--color-green-soft);
  text-align: left;
}

.avatar-picker::after,
.tag-add-button::after {
  border: 0;
}

.avatar-preview,
.preview-avatar {
  display: flex;
  width: 104rpx;
  height: 104rpx;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border: 4rpx solid #ffffff;
  border-radius: 50%;
  background: #ffffff;
}

.avatar-empty,
.preview-avatar-empty {
  color: var(--color-green-dark);
  font-size: 22rpx;
  font-weight: 700;
}

.avatar-copy {
  display: flex;
  min-width: 0;
  flex-direction: column;
  gap: 5rpx;
}

.avatar-title {
  color: var(--color-ink);
  font-size: 28rpx;
  font-weight: 780;
}

.avatar-action {
  color: var(--color-green-dark);
  font-size: 22rpx;
  font-weight: 680;
}

.form-field,
.tag-field {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 22rpx;
  border: 2rpx solid var(--color-line);
  border-radius: 26rpx;
  background: #ffffff;
}

.field-label {
  font-size: 25rpx;
  font-weight: 740;
}

.field-input,
.field-textarea {
  box-sizing: border-box;
  width: 100%;
  border: 0;
  border-radius: 20rpx;
  background: #f6f8f7;
  color: var(--color-ink);
  font-size: 26rpx;
}

.field-input {
  min-height: 82rpx;
  padding: 0 20rpx;
}

.field-textarea {
  min-height: 210rpx;
  padding: 20rpx;
  line-height: 1.55;
}

.field-heading,
.visibility-row,
.preference-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.field-count,
.field-help,
.visibility-help {
  color: var(--color-subtle);
  font-size: 21rpx;
  line-height: 1.5;
}

.tag-options,
.preview-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-option,
.preview-tags text {
  display: inline-flex;
  min-height: 58rpx;
  align-items: center;
  justify-content: center;
  padding: 0 20rpx;
  border: 2rpx solid var(--color-line);
  border-radius: 29rpx;
  background: #ffffff;
  color: var(--color-muted);
  font-size: 23rpx;
}

.tag-option-selected {
  border-color: #a8dfc0;
  background: var(--color-green-soft);
  color: var(--color-green-dark);
  font-weight: 700;
}

.custom-tag-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.custom-tag-input {
  min-width: 0;
  flex: 1;
}

.tag-add-button {
  display: flex;
  min-width: 116rpx;
  min-height: 82rpx;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0 20rpx;
  border-radius: 41rpx;
  background: var(--color-green-soft);
  color: var(--color-green-dark);
  font-size: 24rpx;
  font-weight: 720;
}

.privacy-row,
.connection-note {
  display: flex;
  min-height: 76rpx;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 20rpx;
  border-radius: 22rpx;
  background: var(--color-yellow-soft);
  color: var(--color-muted);
  font-size: 22rpx;
  line-height: 1.5;
}

.privacy-link {
  color: var(--color-green-dark);
  font-weight: 720;
}

.preference-list {
  overflow: hidden;
  border: 2rpx solid var(--color-line);
  border-radius: 26rpx;
  background: #ffffff;
}

.preference-row {
  min-height: 100rpx;
  padding: 0 22rpx;
  border-bottom: 2rpx solid var(--color-line);
  font-size: 25rpx;
}

.preference-row:last-child {
  border-bottom: 0;
}

.profile-preview {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  padding: 28rpx;
  border: 2rpx solid #e3ddff;
  border-radius: var(--radius-card);
  background: var(--color-purple-soft);
}

.preview-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.preview-title {
  display: flex;
  min-width: 0;
  flex-direction: column;
  gap: 6rpx;
}

.preview-title text:first-child {
  font-size: 32rpx;
  font-weight: 810;
}

.preview-title text:last-child,
.preview-copy {
  color: var(--color-muted);
  font-size: 23rpx;
  line-height: 1.55;
}

.preview-section {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.78);
}

.preview-label {
  color: var(--color-purple);
  font-size: 21rpx;
  font-weight: 720;
}

.preview-tags text {
  min-height: 50rpx;
  background: var(--color-purple-soft);
}

.visibility-row {
  align-items: flex-start;
  padding: 24rpx;
  border: 2rpx solid #dcefe5;
  border-radius: 26rpx;
  background: var(--color-green-soft);
}

.visibility-row > view {
  display: flex;
  min-width: 0;
  flex: 1;
  flex-direction: column;
  gap: 6rpx;
}

.form-actions {
  position: sticky;
  z-index: 10;
  bottom: 0;
  display: flex;
  gap: 14rpx;
  margin: 30rpx -32rpx -64rpx;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  border-top: 2rpx solid var(--color-line);
  background: rgba(255, 255, 255, 0.96);
}

.back-button {
  width: 190rpx;
  flex: 0 0 auto;
}

.next-button {
  min-width: 0;
  flex: 1;
}
