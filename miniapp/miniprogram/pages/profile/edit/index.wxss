.profile-form,
.form-heading,
.form-field {
  display: flex;
  flex-direction: column;
}

.profile-form { gap: 30rpx; }
.form-heading { gap: 12rpx; margin-bottom: 8rpx; }
.form-summary { font-size: 25rpx; line-height: 1.6; }
.avatar-picker { display: flex; align-items: center; gap: 20rpx; min-height: 112rpx; margin: 0; padding: 0; border: 0; background: transparent; text-align: left; }
.avatar-picker::after { border: 0; }
.avatar-preview { display: flex; width: 104rpx; height: 104rpx; flex: 0 0 auto; align-items: center; justify-content: center; border-radius: 50%; background: #dcefe8; }
.avatar-empty { color: #0d654a; font-size: 22rpx; }
.avatar-action { color: #147a5b; font-size: 27rpx; font-weight: 650; }
.form-field { gap: 12rpx; }
.field-label { font-size: 26rpx; font-weight: 650; }

.field-input,
.field-textarea {
  box-sizing: border-box;
  width: 100%;
  border: 2rpx solid #cbd3cf;
  border-radius: 8rpx;
  background: #ffffff;
  font-size: 28rpx;
}

.field-input { height: 84rpx; padding: 0 24rpx; }
.field-textarea { min-height: 220rpx; padding: 22rpx 24rpx; line-height: 1.6; }
.preference-list { border-top: 2rpx solid #dce2df; }

.preference-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 96rpx;
  border-bottom: 2rpx solid #dce2df;
  font-size: 27rpx;
}

.privacy-row { display: flex; align-items: center; gap: 8rpx; font-size: 25rpx; line-height: 1.5; }
.privacy-link { color: #147a5b; font-weight: 650; }
