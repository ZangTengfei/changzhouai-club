.account-page {
  padding-top: 18rpx;
}

.account-content {
  display: flex;
  flex-direction: column;
}

.account-error {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  padding-top: 80rpx;
}

.settings-entry {
  display: flex;
  min-height: 72rpx;
  align-items: center;
  align-self: flex-end;
  gap: 10rpx;
  color: var(--color-muted);
  font-size: 25rpx;
}

.settings-entry image {
  width: 36rpx;
  height: 36rpx;
}

.identity-hero {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 30rpx;
  border: 2rpx solid #def0e6;
  border-radius: 36rpx;
  background: #f1fbf5;
}

.identity-main {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  display: flex;
  width: 146rpx;
  height: 146rpx;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border: 6rpx solid rgba(255, 255, 255, 0.92);
  border-radius: 50%;
  background: var(--color-green-soft);
}

.avatar-placeholder {
  color: var(--color-green-dark);
  font-size: 50rpx;
  font-weight: 800;
}

.identity-copy {
  display: flex;
  min-width: 0;
  flex: 1;
  flex-direction: column;
  gap: 8rpx;
}

.profile-name {
  font-size: 42rpx;
  font-weight: 830;
  line-height: 1.25;
}

.profile-meta,
.joined-label {
  overflow: hidden;
  color: var(--color-subtle);
  font-size: 24rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.identity-pill {
  display: flex;
  width: fit-content;
  min-height: 48rpx;
  align-items: center;
  gap: 8rpx;
  padding: 2rpx 14rpx 2rpx 6rpx;
  border: 2rpx solid #f0d88f;
  border-radius: 24rpx;
  background: var(--color-yellow-soft);
  color: var(--color-green-dark);
  font-size: 23rpx;
  font-weight: 720;
}

.identity-pill image {
  width: 38rpx;
  height: 38rpx;
}

.profile-completion {
  padding: 24rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.88);
}

.profile-completion-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.profile-completion-heading text:first-child {
  font-size: 28rpx;
  font-weight: 800;
}

.profile-completion-heading text:last-child {
  color: var(--color-green-dark);
  font-size: 23rpx;
  font-weight: 720;
}

.profile-completion-copy {
  display: block;
  margin-top: 8rpx;
  color: var(--color-subtle);
  font-size: 22rpx;
  line-height: 1.5;
}

.profile-completion-track {
  height: 12rpx;
  margin-top: 18rpx;
  overflow: hidden;
  border-radius: 6rpx;
  background: #dcefe5;
}

.profile-completion-track view {
  height: 100%;
  border-radius: 6rpx;
  background: var(--color-green);
}

.stats-card {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  margin-top: 22rpx;
  padding: 26rpx 10rpx;
}

.stat-item {
  display: flex;
  min-width: 0;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  border-right: 2rpx solid var(--color-line);
}

.stat-item:last-child {
  border-right: 0;
}

.stat-item text:first-child {
  font-size: 38rpx;
  font-weight: 820;
}

.stat-item text:last-child {
  color: var(--color-subtle);
  font-size: 22rpx;
}

.space-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.space-card {
  position: relative;
  display: flex;
  min-height: 194rpx;
  box-sizing: border-box;
  flex-direction: column;
  justify-content: flex-end;
  padding: 22rpx;
  border: 2rpx solid rgba(17, 23, 21, 0.03);
  border-radius: 28rpx;
}

.space-green {
  background: var(--color-green-soft);
}

.space-orange {
  background: var(--color-orange-soft);
}

.space-blue {
  background: var(--color-blue-soft);
}

.space-purple {
  background: var(--color-purple-soft);
}

.space-card .icon-tile {
  position: absolute;
  top: 18rpx;
  left: 18rpx;
  width: 58rpx;
  height: 58rpx;
  border-radius: 0;
  background: transparent;
}

.space-card .icon-tile image {
  width: 50rpx;
  height: 50rpx;
}

.space-title {
  padding-right: 34rpx;
  font-size: 28rpx;
  font-weight: 790;
}

.space-copy {
  margin-top: 6rpx;
  color: var(--color-subtle);
  font-size: 22rpx;
}

.space-arrow {
  position: absolute;
  right: 18rpx;
  bottom: 28rpx;
  box-sizing: border-box;
  width: 42rpx;
  height: 42rpx;
  padding: 10rpx;
  border-radius: 50%;
  opacity: 1;
}

.space-green .space-arrow {
  background: #ccf2dd;
}

.space-orange .space-arrow {
  background: #ffe0bd;
}

.space-blue .space-arrow {
  background: #d9eaff;
}

.space-purple .space-arrow {
  background: #e4dcff;
}

.recent-event {
  display: flex;
  min-height: 132rpx;
  align-items: center;
  gap: 18rpx;
  padding: 16rpx;
}

.recent-cover {
  box-sizing: border-box;
  width: 168rpx;
  height: 104rpx;
  flex: 0 0 auto;
  border-radius: 20rpx;
  background: #edf1ef;
}

.recent-placeholder {
  padding: 26rpx;
}

.recent-copy {
  display: flex;
  min-width: 0;
  flex: 1;
  flex-direction: column;
  gap: 8rpx;
}

.recent-title {
  display: -webkit-box;
  overflow: hidden;
  font-size: 27rpx;
  font-weight: 780;
  line-height: 1.35;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.recent-copy text:last-child {
  color: var(--color-subtle);
  font-size: 21rpx;
}

.recent-status {
  flex: 0 0 auto;
  padding: 5rpx 12rpx;
  border: 2rpx solid #a9dfc1;
  border-radius: 18rpx;
  color: var(--color-green-dark);
  font-size: 20rpx;
}

.honor-strip {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 24rpx;
  padding: 24rpx;
  border: 2rpx solid #f1e3ac;
  border-radius: 28rpx;
  background: var(--color-yellow-soft);
}

.honor-heading {
  font-size: 27rpx;
  font-weight: 790;
}

.honor-items {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx 24rpx;
}

.honor-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: var(--color-muted);
  font-size: 21rpx;
}

.honor-item image {
  width: 44rpx;
  height: 44rpx;
}
