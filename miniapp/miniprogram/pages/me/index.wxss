.account-error,
.account-content {
  display: flex;
  flex-direction: column;
  gap: 34rpx;
}

.identity-band {
  margin: -8rpx -28rpx 0;
  padding: 22rpx 28rpx 0;
  border-bottom: 2rpx solid var(--color-line);
  background: var(--color-surface);
}

.identity-toolbar {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  align-items: center;
  gap: 20rpx;
}

.identity-kicker {
  color: var(--color-green);
  font-size: 22rpx;
  font-weight: 760;
}

.settings-button {
  display: flex;
  min-height: 72rpx;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
  width: auto;
  margin: -14rpx 0 -14rpx auto;
  padding-left: 16rpx;
  color: var(--color-muted);
  font-size: 23rpx;
  line-height: 1;
}

.settings-button image {
  width: 34rpx;
  height: 34rpx;
}

.profile-header {
  display: grid;
  grid-template-columns: 116rpx minmax(0, 1fr);
  align-items: center;
  gap: 22rpx;
  padding: 20rpx 0 26rpx;
}

.avatar {
  display: flex;
  width: 116rpx;
  height: 116rpx;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--color-green-soft);
}

.avatar-placeholder {
  color: var(--color-green-dark);
  font-size: 42rpx;
  font-weight: 760;
}

.profile-copy,
.section-copy,
.footprint-copy {
  display: flex;
  min-width: 0;
  flex-direction: column;
}

.profile-copy {
  gap: 8rpx;
}

.profile-name {
  overflow: hidden;
  font-size: 40rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-meta {
  display: -webkit-box;
  overflow: hidden;
  color: var(--color-muted);
  font-size: 24rpx;
  line-height: 1.45;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.identity-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.identity-label,
.honor-tag {
  width: fit-content;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  background: var(--color-green-soft);
  color: var(--color-green-dark);
  font-size: 21rpx;
  line-height: 1.35;
}

.honor-tag {
  background: var(--color-orange-soft);
  color: #854a22;
}

.growth-entry {
  display: flex;
  min-height: 70rpx;
  align-items: center;
  justify-content: space-between;
  border-top: 2rpx solid var(--color-line);
  color: var(--color-muted);
  font-size: 23rpx;
}

.growth-entry image,
.row-arrow,
.compact-empty image {
  width: 28rpx;
  height: 28rpx;
}

.account-section {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.section-heading {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
}

.section-copy {
  gap: 5rpx;
}

.activity-summary {
  color: var(--color-subtle);
  font-size: 22rpx;
}

.text-action {
  min-height: 64rpx;
  margin: -14rpx 0;
  padding: 0 0 0 20rpx;
  background: transparent;
  color: var(--color-green);
  font-size: 24rpx;
  line-height: 1;
}

.text-action::after {
  border: 0;
}

.footprint-row {
  display: grid;
  grid-template-columns: 126rpx minmax(0, 1fr) 28rpx;
  align-items: center;
  gap: 14rpx;
  min-height: 118rpx;
  padding: 18rpx 0;
  border-top: 2rpx solid var(--color-ink);
  border-bottom: 2rpx solid var(--color-line);
}

.footprint-date {
  display: flex;
  align-self: stretch;
  justify-content: center;
  flex-direction: column;
  gap: 5rpx;
  padding-right: 14rpx;
  border-right: 2rpx solid var(--color-line);
  color: var(--color-green);
  font-size: 22rpx;
}

.footprint-copy {
  gap: 6rpx;
}

.footprint-title {
  display: -webkit-box;
  overflow: hidden;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.4;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.footprint-location {
  overflow: hidden;
  color: var(--color-subtle);
  font-size: 22rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.compact-empty {
  display: flex;
  min-height: 92rpx;
  align-items: center;
  justify-content: space-between;
  border-top: 2rpx solid var(--color-ink);
  border-bottom: 2rpx solid var(--color-line);
  color: var(--color-subtle);
  font-size: 23rpx;
}
