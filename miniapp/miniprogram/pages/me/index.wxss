.account-error,
.account-content {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.member-band {
  margin: -8rpx -28rpx 0;
  padding: 28rpx 28rpx 0;
  background: var(--color-ink);
  color: #ffffff;
}

.passport-kicker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 18rpx;
  border-bottom: 2rpx solid rgba(255, 255, 255, 0.13);
  color: #9fd7c4;
  font-size: 19rpx;
  font-weight: 700;
}

.profile-header {
  display: grid;
  grid-template-columns: 112rpx minmax(0, 1fr) 92rpx;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 0;
}

.avatar {
  display: flex;
  width: 112rpx;
  height: 112rpx;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #dcefe8;
}

.avatar-placeholder {
  color: var(--color-green-dark);
  font-size: 42rpx;
  font-weight: 760;
}

.profile-copy,
.next-action-copy,
.badge-copy,
.footprint-copy {
  display: flex;
  min-width: 0;
  flex-direction: column;
}

.profile-copy {
  gap: 7rpx;
}

.identity-label {
  width: fit-content;
  padding: 4rpx 10rpx;
  border: 2rpx solid rgba(159, 215, 196, 0.45);
  border-radius: 6rpx;
  color: #9fd7c4;
  font-size: 21rpx;
  line-height: 1.3;
}

.profile-name {
  overflow: hidden;
  font-size: 38rpx;
  font-weight: 780;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-meta {
  overflow: hidden;
  color: #c8d0cd;
  font-size: 23rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.joined-label {
  color: #93a19b;
  font-size: 21rpx;
}

.level-badge {
  width: 92rpx;
  height: 92rpx;
}

.next-action {
  display: grid;
  grid-template-columns: 82rpx minmax(0, 1fr) 32rpx;
  align-items: center;
  gap: 18rpx;
  padding: 24rpx 0 28rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.13);
}

.next-action-index {
  display: flex;
  align-self: stretch;
  justify-content: center;
  flex-direction: column;
  gap: 2rpx;
  border-right: 2rpx solid rgba(255, 255, 255, 0.13);
  color: #9fd7c4;
  font-size: 19rpx;
}

.next-action-index text:last-child {
  font-size: 31rpx;
  font-weight: 760;
}

.next-action-copy {
  gap: 6rpx;
}

.next-action-title {
  font-size: 29rpx;
  font-weight: 760;
}

.next-action-description {
  color: #aebbb6;
  font-size: 21rpx;
  line-height: 1.45;
}

.next-action image {
  width: 32rpx;
  height: 32rpx;
}

.member-stats {
  display: grid;
  height: 128rpx;
  margin: -28rpx -28rpx 0;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  border-bottom: 2rpx solid var(--color-line);
  background: var(--color-surface);
}

.stat-item {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 5rpx;
}

.stat-item + .stat-item {
  border-left: 2rpx solid var(--color-line);
}

.stat-value {
  color: var(--color-green);
  font-size: 38rpx;
  font-weight: 780;
}

.stat-value-warm {
  color: #b57600;
}

.stat-label {
  color: var(--color-subtle);
  font-size: 21rpx;
}

.growth-section {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  padding: 4rpx 0 28rpx;
  border-bottom: 2rpx solid var(--color-line);
}

.growth-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.growth-heading > view {
  display: flex;
  min-width: 0;
  flex-direction: column;
  gap: 7rpx;
}

.growth-heading image {
  width: 82rpx;
  height: 82rpx;
}

.growth-note {
  color: var(--color-subtle);
  font-size: 21rpx;
}

.growth-steps {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

.growth-step {
  padding: 16rpx 4rpx 0;
  border-top: 4rpx solid #cbd3cf;
  color: var(--color-subtle);
  font-size: 20rpx;
  text-align: center;
}

.growth-step-complete,
.growth-step-current {
  border-top-color: var(--color-green);
  color: var(--color-green);
}

.growth-step-current {
  font-weight: 760;
}

.profile-prompt {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 26rpx;
  border-left: 8rpx solid var(--color-orange);
  background: var(--color-orange-soft);
}

.profile-prompt-title {
  font-size: 29rpx;
  font-weight: 740;
}

.profile-prompt-copy {
  color: #603225;
  font-size: 24rpx;
  line-height: 1.6;
}

.prompt-button {
  min-height: 72rpx;
  margin-top: 8rpx;
  font-size: 26rpx;
}

.account-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.account-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 8rpx;
}

.section-heading {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
}

.section-note {
  color: var(--color-subtle);
  font-size: 21rpx;
}

.text-action {
  margin: 0;
  padding: 8rpx 0 8rpx 20rpx;
  background: transparent;
  color: var(--color-green);
  font-size: 23rpx;
  line-height: 1;
}

.text-action::after {
  border: 0;
}

.badge-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.badge-item {
  display: flex;
  min-width: 0;
  align-items: center;
  gap: 14rpx;
  padding: 17rpx;
  border: 2rpx solid var(--color-line);
  border-radius: 8rpx;
  background: var(--color-surface);
}

.badge-mark {
  width: 52rpx;
  height: 52rpx;
  flex: 0 0 auto;
}

.badge-copy {
  gap: 4rpx;
}

.badge-name {
  font-size: 24rpx;
  font-weight: 700;
}

.badge-description {
  display: -webkit-box;
  overflow: hidden;
  color: var(--color-subtle);
  font-size: 20rpx;
  line-height: 1.35;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.footprint-list,
.channel-list {
  border-top: 2rpx solid var(--color-line);
}

.footprint-row {
  display: grid;
  grid-template-columns: 126rpx minmax(0, 1fr) 28rpx;
  align-items: center;
  gap: 14rpx;
  min-height: 116rpx;
  padding: 18rpx 0;
  border-bottom: 2rpx solid var(--color-line);
}

.footprint-date {
  display: flex;
  align-self: stretch;
  justify-content: center;
  flex-direction: column;
  gap: 5rpx;
  padding-right: 14rpx;
  border-right: 2rpx solid var(--color-line);
  color: var(--color-green);
  font-size: 20rpx;
}

.footprint-copy {
  gap: 6rpx;
}

.footprint-title {
  display: -webkit-box;
  overflow: hidden;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.4;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.footprint-location {
  overflow: hidden;
  color: var(--color-subtle);
  font-size: 21rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.row-arrow {
  width: 28rpx;
  height: 28rpx;
}

.compact-empty {
  padding: 24rpx 0;
  border-top: 2rpx solid var(--color-line);
  border-bottom: 2rpx solid var(--color-line);
  color: var(--color-subtle);
  font-size: 23rpx;
  line-height: 1.6;
}

.channel-row {
  display: flex;
  min-height: 82rpx;
  align-items: center;
  justify-content: space-between;
  border-bottom: 2rpx solid var(--color-line);
  font-size: 26rpx;
}

.secondary-channel {
  text-transform: none;
}

.channel-status {
  color: var(--color-green);
  font-size: 22rpx;
}

.logout-button {
  margin-top: 20rpx;
}
