<custom-navigation title="我的" />

<view class="page-shell account-page">
  <view wx:if="{{loading}}" class="empty-state">正在加载成员档案</view>

  <view wx:elif="{{loggedOut}}" class="account-error">
    <text class="section-title">已退出当前账号</text>
    <text class="muted">重新进入后，可以继续使用微信登录。</text>
    <button class="primary-button" bindtap="loadAccount">重新登录</button>
  </view>

  <view wx:elif="{{loginFailed}}" class="account-error">
    <text class="section-title">暂时无法登录</text>
    <text class="muted">请检查网络后重新尝试。</text>
    <button class="primary-button" bindtap="loadAccount">重新登录</button>
  </view>

  <view wx:elif="{{user}}" class="account-content">
    <view class="identity-hero">
      <view class="account-settings-button" bindtap="openSettings" role="button" aria-label="打开账号设置">
        <image src="/assets/icons/settings-purple-v2.png" mode="aspectFit" />
      </view>
      <view class="identity-main" bindtap="openGrowth" role="button" aria-label="查看成长档案">
        <image wx:if="{{user.avatarUrl}}" class="avatar" src="{{user.avatarUrl}}" mode="aspectFill" />
        <view wx:else class="avatar avatar-placeholder">{{avatarInitial}}</view>
        <view class="identity-copy">
          <text class="profile-name">{{user.displayName}}</text>
          <text class="profile-meta">{{user.roleLabel || user.city}}{{user.organization ? ' · ' + user.organization : ''}}</text>
          <view class="identity-pill"><image src="/assets/badges/level-3-core-builder-128.png" mode="aspectFit" /><text>{{user.identityLabel}}</text></view>
          <text class="joined-label">{{joinedLabel}}</text>
        </view>
      </view>

      <view class="profile-completion" bindtap="openProfile" role="button" aria-label="继续完善能力档案">
        <view class="profile-completion-heading"><text>能力档案 {{user.profileCompletion.percent}}%</text><text>继续完善</text></view>
        <text class="profile-completion-copy">{{user.profileCompletion.completed ? '档案已完善，可以随时更新' : '再补充 ' + user.profileCompletion.missingItems.length + ' 项，让更多伙伴了解你'}}</text>
        <view class="profile-completion-track"><view style="width: {{user.profileCompletion.percent}}%;"></view></view>
      </view>
    </view>

    <view class="stats-card surface-card">
      <view class="stat-item"><text>{{user.stats.registrationCount}}</text><text>活动报名</text></view>
      <view class="stat-item"><text>{{user.stats.attendanceCount}}</text><text>实际到场</text></view>
      <view class="stat-item"><text>{{user.stats.badgeCount}}</text><text>社区荣誉</text></view>
    </view>

    <view class="section-heading-row"><text class="section-title">我的空间</text></view>
    <view class="space-grid">
      <view class="space-card space-green space-card-featured" bindtap="openGrowth" role="button">
        <view class="icon-tile"><image src="/assets/icons/growth-purple-v2.png" mode="aspectFit" /></view>
        <text class="space-title">成长档案</text><text class="space-copy">查看身份路径</text>
        <image class="space-arrow" src="/assets/icons/chevron-green-v2.png" mode="aspectFit" />
      </view>
      <view class="space-card space-orange" bindtap="openRegistrations" role="button">
        <view class="icon-tile"><image src="/assets/icons/events-orange-v2.png" mode="aspectFit" /></view>
        <text class="space-title">我的活动</text><text class="space-copy">{{user.stats.registrationCount}} 场记录</text>
        <image class="space-arrow" src="/assets/icons/chevron-orange-v2.png" mode="aspectFit" />
      </view>
      <view class="space-card space-blue" bindtap="openProfile" role="button">
        <view class="icon-tile"><image src="/assets/icons/profile-blue-v2.png" mode="aspectFit" /></view>
        <text class="space-title">能力档案</text><text class="space-copy">技能与方向</text>
        <image class="space-arrow" src="/assets/icons/chevron-blue-v2.png" mode="aspectFit" />
      </view>
    </view>

    <view class="section-heading-row">
      <text class="section-title">最近参与</text>
      <view class="section-action" bindtap="openRegistrations" role="button">查看全部</view>
    </view>
    <view wx:if="{{latestFootprint}}" class="recent-event surface-card" data-slug="{{latestFootprint.slug}}" bindtap="openEvent">
      <image wx:if="{{latestFootprint.cover_image_url}}" class="recent-cover" src="{{latestFootprint.cover_image_url}}" mode="aspectFill" />
      <image wx:else class="recent-cover recent-placeholder" src="/assets/logo-mark.png" mode="aspectFit" />
      <view class="recent-copy"><text class="recent-title">{{latestFootprint.title}}</text><text>{{latestFootprint.dateLabel}} · {{latestFootprint.locationLabel}}</text></view>
      <text class="recent-status">{{latestFootprint.participationLabel}}</text>
      <image class="row-arrow" src="/assets/icons/chevron-soft-v2.png" mode="aspectFit" />
    </view>
    <view wx:else class="empty-state" bindtap="openEvents" role="button">还没有活动记录，去看看社区活动</view>

    <view class="honor-strip">
      <text class="honor-heading">社区荣誉</text>
      <view class="honor-items">
        <view class="honor-item"><image src="/assets/badges/level-3-core-builder-128.png" mode="aspectFit" /><text>{{user.identityLabel}}</text></view>
        <view wx:for="{{honorTags}}" wx:key="code" class="honor-item"><image src="/assets/logo-mark.png" mode="aspectFit" /><text>{{item.label}}</text></view>
      </view>
    </view>
  </view>
</view>
