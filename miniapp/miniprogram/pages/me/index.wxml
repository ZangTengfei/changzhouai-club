<custom-navigation />
<view class="page-shell account-page">
  <view wx:if="{{loading}}" class="empty-state">正在加载成员档案</view>

  <view wx:elif="{{loggedOut}}" class="account-error">
    <text class="section-title">已退出当前账号</text>
    <button class="primary-button" bindtap="loadAccount">重新登录</button>
  </view>

  <view wx:elif="{{loginFailed}}" class="account-error">
    <text class="section-title">暂时无法登录</text>
    <text class="muted">请检查网络后重新尝试。</text>
    <button class="primary-button" bindtap="loadAccount">重新登录</button>
  </view>

  <view wx:elif="{{user}}" class="account-content">
    <view class="identity-band" bindtap="openGrowth" role="button" aria-label="查看成长档案">
      <view class="identity-toolbar">
        <text class="identity-kicker">成员档案</text>
        <view class="settings-button" catchtap="openSettings" role="button" aria-label="打开设置">
          <image src="/assets/icons/settings.png" mode="aspectFit" />
          <text>设置</text>
        </view>
      </view>
      <view class="profile-header">
        <image wx:if="{{user.avatarUrl}}" class="avatar" src="{{user.avatarUrl}}" mode="aspectFill" />
        <view wx:else class="avatar avatar-placeholder">{{avatarInitial}}</view>
        <view class="profile-copy">
          <text class="profile-name">{{user.displayName}}</text>
          <text class="profile-meta">{{user.roleLabel || user.city}}{{user.organization ? ' · ' + user.organization : ''}}</text>
          <view class="identity-tags">
            <text class="identity-label">{{user.identityLabel}}</text>
            <text wx:for="{{honorTags}}" wx:key="code" class="honor-tag">{{item.label}}</text>
          </view>
        </view>
      </view>
      <view class="growth-entry">
        <text>查看成长档案</text>
        <image src="/assets/icons/chevron-right.png" mode="aspectFit" />
      </view>
    </view>

    <view class="account-section activity-section">
      <view class="section-heading">
        <view class="section-copy">
          <text class="section-title">我的活动</text>
          <text class="activity-summary">{{activitySummary}}</text>
        </view>
        <button class="text-action" bindtap="openRegistrations">查看全部</button>
      </view>
      <view wx:if="{{latestFootprint}}" class="footprint-row" data-slug="{{latestFootprint.slug}}" bindtap="openEvent">
        <view class="footprint-date"><text>{{latestFootprint.dateLabel}}</text><text>{{latestFootprint.participationLabel}}</text></view>
        <view class="footprint-copy"><text class="footprint-title">{{latestFootprint.title}}</text><text class="footprint-location">{{latestFootprint.locationLabel}}</text></view>
        <image class="row-arrow" src="/assets/icons/chevron-right.png" mode="aspectFit" />
      </view>
      <view wx:else class="compact-empty" bindtap="openEvents" role="button">
        <text>还没有活动记录，去看看社区活动</text>
        <image src="/assets/icons/chevron-right.png" mode="aspectFit" />
      </view>
    </view>
  </view>
</view>
