<custom-navigation />
<view class="page-shell account-page">
  <view wx:if="{{loading}}" class="empty-state">正在加载成员档案</view>

  <view wx:elif="{{loggedOut}}" class="account-error">
    <text class="section-title">已退出当前账号</text>
    <button class="primary-button" bindtap="loadAccount">重新登录</button>
  </view>

  <view wx:elif="{{loginFailed}}" class="account-error">
    <text class="section-title">暂时无法登录</text>
    <text class="muted">请检查网络后重新尝试。</text>
    <button class="primary-button" bindtap="loadAccount">重新登录</button>
  </view>

  <view wx:elif="{{user}}" class="account-content">
    <view class="identity-band">
      <view class="identity-toolbar">
        <text class="identity-kicker">成员档案</text>
        <view class="settings-button" bindtap="openSettings" role="button" aria-label="打开设置">
          <image src="/assets/icons/settings.png" mode="aspectFit" />
          <text>设置</text>
        </view>
      </view>
      <view class="profile-header">
        <image wx:if="{{user.avatarUrl}}" class="avatar" src="{{user.avatarUrl}}" mode="aspectFill" />
        <view wx:else class="avatar avatar-placeholder">{{avatarInitial}}</view>
        <view class="profile-copy">
          <text class="identity-label">{{user.identityLabel}}</text>
          <text class="profile-name">{{user.displayName}}</text>
          <text class="profile-meta">{{user.roleLabel || user.city}}{{user.organization ? ' · ' + user.organization : ''}}</text>
          <text class="joined-label">{{joinedLabel}}</text>
        </view>
      </view>
    </view>

    <view class="next-action" bindtap="handleNextAction" role="button">
      <view class="next-action-index"><text>NEXT</text><text>01</text></view>
      <view class="next-action-copy"><text class="next-action-title">{{nextActionTitle}}</text><text class="next-action-description">{{nextActionCopy}}</text></view>
      <image src="/assets/icons/chevron-right-active.png" mode="aspectFit" />
    </view>

    <view wx:if="{{!user.profileComplete}}" class="profile-prompt">
      <text class="profile-prompt-title">完善社区资料</text>
      <text class="profile-prompt-copy">补充昵称和微信号后，报名活动时会更方便联系。</text>
      <button class="primary-button prompt-button" bindtap="openProfile">现在完善</button>
    </view>

    <view class="account-section activity-section">
      <view class="section-heading">
        <text class="section-title">我的活动</text>
        <button class="text-action" bindtap="openRegistrations">查看全部</button>
      </view>
      <view class="activity-stats">
        <view class="stat-item"><text class="stat-value">{{user.stats.registrationCount}}</text><text class="stat-label">活动报名</text></view>
        <view class="stat-item"><text class="stat-value">{{user.stats.attendanceCount}}</text><text class="stat-label">实际到场</text></view>
      </view>
      <view wx:if="{{footprints.length}}" class="footprint-list">
        <view wx:for="{{footprints}}" wx:key="id" class="footprint-row" data-slug="{{item.slug}}" bindtap="openEvent">
          <view class="footprint-date"><text>{{item.dateLabel}}</text><text>{{item.participationLabel}}</text></view>
          <view class="footprint-copy"><text class="footprint-title">{{item.title}}</text><text class="footprint-location">{{item.locationLabel}}</text></view>
          <image class="row-arrow" src="/assets/icons/chevron-right.png" mode="aspectFit" />
        </view>
      </view>
      <view wx:else class="compact-empty">还没有活动记录，先去看看社区活动。</view>
    </view>

    <view class="growth-section">
      <view class="growth-heading">
        <image src="{{currentLevelAsset}}" mode="aspectFit" />
        <view><text class="section-title">成长进度</text><text class="growth-note">当前 {{currentLevelLabel}} · 下一阶段 {{nextLevelLabel}}</text></view>
      </view>
      <view class="growth-steps">
        <view wx:for="{{growthSteps}}" wx:key="label" class="growth-step {{item.stateClass}}">{{item.label}}</view>
      </view>
    </view>

    <view wx:if="{{honorBadges.length}}" class="account-section">
      <view class="section-heading">
        <text class="section-title">社区荣誉</text>
        <text class="section-note">真实参与和社区授予</text>
      </view>
      <view class="badge-list">
        <view wx:for="{{honorBadges}}" wx:key="code" class="badge-item">
          <image class="badge-mark" src="/assets/logo-mark.webp" mode="aspectFit" />
          <view class="badge-copy"><text class="badge-name">{{item.label}}</text><text class="badge-description">{{item.description}}</text></view>
        </view>
      </view>
    </view>
  </view>
</view>
