.home-page {
  padding-top: 20rpx;
}

.brief-heading-copy,
.feature-body,
.event-body {
  display: flex;
  min-width: 0;
  flex-direction: column;
}

.brief-heading {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 0;
  padding: 30rpx 0 24rpx;
  border-top: 6rpx solid var(--color-orange);
}

.brief-heading-copy {
  gap: 4rpx;
}

.brief-title {
  font-size: 48rpx;
  font-weight: 820;
  line-height: 1.15;
}

.brief-caption {
  color: var(--color-subtle);
  font-size: 18rpx;
  font-weight: 650;
}

.brief-date {
  color: var(--color-green);
  font-size: 24rpx;
  font-weight: 700;
  white-space: nowrap;
}

.profile-progress {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 10rpx 20rpx;
  margin-bottom: 28rpx;
  padding: 22rpx 24rpx;
  border: 2rpx solid #c9d9d3;
  border-radius: 8rpx;
  background: var(--color-green-soft);
}

.profile-progress-copy {
  display: flex;
  min-width: 0;
  flex-direction: column;
  gap: 6rpx;
}

.profile-progress-kicker,
.profile-progress-action {
  color: var(--color-green-dark);
  font-size: 22rpx;
  font-weight: 700;
}

.profile-progress-title {
  overflow: hidden;
  font-size: 25rpx;
  font-weight: 680;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-progress-action {
  align-self: center;
  white-space: nowrap;
}

.profile-progress-track {
  grid-column: 1 / -1;
  overflow: hidden;
  height: 6rpx;
  border-radius: 3rpx;
  background: rgba(15, 122, 106, 0.16);
}

.profile-progress-track view {
  height: 100%;
  border-radius: 3rpx;
  background: var(--color-green);
}

.feature-record {
  padding-bottom: 32rpx;
  border-bottom: 2rpx solid var(--color-green);
}

.feature-cover {
  display: flex;
  width: 100%;
  height: 360rpx;
  align-items: center;
  justify-content: center;
  background: #e8edeb;
}

.feature-cover-placeholder image {
  width: 116rpx;
  height: 116rpx;
}

.feature-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx 0;
  border-bottom: 2rpx solid var(--color-line);
  color: var(--color-green);
  font-size: 22rpx;
  font-weight: 650;
}

.feature-copy {
  display: grid;
  grid-template-columns: 92rpx minmax(0, 1fr);
  gap: 22rpx;
  padding: 28rpx 0 22rpx;
}

.feature-index,
.event-index {
  color: var(--color-green);
  font-weight: 760;
}

.feature-index {
  padding-top: 2rpx;
  border-right: 2rpx solid var(--color-line);
  font-size: 64rpx;
  line-height: 1;
}

.feature-body {
  gap: 10rpx;
}

.feature-title {
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.3;
}

.feature-location,
.event-location {
  color: var(--color-subtle);
}

.feature-location {
  font-size: 24rpx;
}

.feature-summary {
  display: -webkit-box;
  overflow: hidden;
  color: var(--color-muted);
  font-size: 25rpx;
  line-height: 1.65;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.brief-action {
  display: flex;
  width: 190rpx;
  min-height: 68rpx;
  align-items: center;
  justify-content: center;
  margin: 0 0 0 auto;
  border: 2rpx solid var(--color-green);
  border-radius: 6rpx;
  background: transparent;
  color: var(--color-green);
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1;
}

.brief-action::after {
  border: 0;
}

.section-heading {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  align-items: center;
  column-gap: 20rpx;
  margin-top: 34rpx;
  padding-bottom: 20rpx;
}

.text-action {
  display: flex;
  align-items: center;
  justify-self: end;
  min-height: 64rpx;
  margin: 0;
  padding: 0 0 0 20rpx;
  background: transparent;
  color: var(--color-green);
  font-size: 24rpx;
  font-weight: 650;
  line-height: 1;
  white-space: nowrap;
}

.event-list {
  border-top: 2rpx solid var(--color-line);
}

.event-row {
  display: grid;
  grid-template-columns: 54rpx 164rpx minmax(0, 1fr) 28rpx;
  align-items: center;
  gap: 14rpx;
  min-height: 148rpx;
  padding: 22rpx 0;
  border-bottom: 2rpx solid var(--color-line);
}

.event-index {
  font-size: 25rpx;
}

.event-cover {
  width: 164rpx;
  height: 116rpx;
  border-radius: 6rpx;
  background: #e8edeb;
}

.event-cover-placeholder {
  box-sizing: border-box;
  padding: 28rpx;
}

.event-body {
  gap: 8rpx;
}

.event-meta {
  color: var(--color-green);
  font-size: 21rpx;
  font-weight: 650;
}

.event-title {
  display: -webkit-box;
  overflow: hidden;
  font-size: 28rpx;
  font-weight: 760;
  line-height: 1.35;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.event-location {
  overflow: hidden;
  font-size: 21rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.event-arrow,
.archive-note image {
  width: 28rpx;
  height: 28rpx;
}

.archive-note {
  display: flex;
  min-height: 84rpx;
  align-items: center;
  gap: 10rpx;
  color: var(--color-subtle);
  font-size: 23rpx;
}

.archive-count {
  flex: 1;
  color: var(--color-green);
  font-weight: 700;
}

.content-heading {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  align-items: center;
  column-gap: 20rpx;
  margin-top: 22rpx;
  padding: 26rpx 0 18rpx;
  border-top: 2rpx solid var(--color-line);
}

.content-highlight,
.digest-highlight {
  display: flex;
  flex-direction: column;
}

.content-highlight {
  gap: 10rpx;
  padding: 22rpx 0 24rpx;
  border-top: 6rpx solid var(--color-orange);
  border-bottom: 2rpx solid var(--color-line);
}

.content-highlight-meta {
  display: flex;
  gap: 12rpx;
  color: var(--color-green);
  font-size: 21rpx;
  font-weight: 720;
}

.content-highlight-meta text:last-child {
  overflow: hidden;
  color: var(--color-subtle);
  text-overflow: ellipsis;
  white-space: nowrap;
}

.content-highlight-title,
.digest-highlight-title {
  display: -webkit-box;
  overflow: hidden;
  font-weight: 780;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.content-highlight-title {
  font-size: 31rpx;
  line-height: 1.38;
}

.content-highlight-summary,
.digest-highlight-copy {
  display: -webkit-box;
  overflow: hidden;
  color: var(--color-muted);
  font-size: 23rpx;
  line-height: 1.58;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.digest-highlight {
  position: relative;
  gap: 9rpx;
  padding: 22rpx 42rpx 24rpx 0;
  border-bottom: 2rpx solid var(--color-line);
}

.digest-highlight-label {
  color: var(--color-green);
  font-size: 21rpx;
  font-weight: 720;
}

.digest-highlight-title {
  font-size: 28rpx;
  line-height: 1.4;
}

.digest-highlight image {
  position: absolute;
  top: 50%;
  right: 0;
  width: 28rpx;
  height: 28rpx;
  transform: translateY(-50%);
}
