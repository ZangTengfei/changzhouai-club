.home-page {
  padding-top: 34rpx;
}

.welcome-block {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-bottom: 34rpx;
}

.welcome-title {
  font-size: 56rpx;
  font-weight: 840;
  line-height: 1.18;
}

.welcome-copy {
  color: var(--color-subtle);
  font-size: 28rpx;
  line-height: 1.55;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.quick-card {
  position: relative;
  display: flex;
  box-sizing: border-box;
  min-width: 0;
  min-height: 226rpx;
  flex-direction: column;
  justify-content: flex-end;
  padding: 22rpx;
  overflow: hidden;
  border: 2rpx solid rgba(17, 23, 21, 0.03);
  border-radius: 30rpx;
}

.quick-card-blue {
  background: var(--color-blue-soft);
}

.quick-card-orange {
  background: var(--color-orange-soft);
}

.quick-card-green {
  background: var(--color-green-soft);
}

.quick-card-purple {
  background: var(--color-purple-soft);
}

.quick-card .icon-tile {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  width: 62rpx;
  height: 62rpx;
  border-radius: 0;
  background: transparent;
}

.quick-card .icon-tile image {
  width: 54rpx;
  height: 54rpx;
}

.quick-title {
  padding-right: 44rpx;
  font-size: 31rpx;
  font-weight: 800;
  line-height: 1.25;
}

.quick-copy {
  display: block;
  overflow: hidden;
  margin-top: 8rpx;
  color: var(--color-muted);
  font-size: 23rpx;
  line-height: 1.45;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.quick-arrow {
  position: absolute;
  right: 20rpx;
  bottom: 34rpx;
  box-sizing: border-box;
  width: 48rpx;
  height: 48rpx;
  padding: 11rpx;
  border-radius: 50%;
  opacity: 1;
}

.quick-arrow-blue {
  background: #d9eaff;
}

.quick-arrow-orange {
  background: #ffe0bd;
}

.quick-arrow-green {
  background: #ccf2dd;
}

.quick-arrow-purple {
  background: #e4dcff;
}

.featured-card {
  overflow: hidden;
}

.featured-cover {
  display: flex;
  width: 100%;
  height: 360rpx;
  align-items: center;
  justify-content: center;
  background: #edf1ef;
}

.featured-placeholder image {
  width: 128rpx;
  height: 128rpx;
}

.featured-content {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 28rpx;
}

.featured-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: var(--color-subtle);
  font-size: 22rpx;
  font-weight: 650;
}

.featured-title {
  font-size: 38rpx;
  font-weight: 820;
  line-height: 1.3;
}

.featured-detail {
  color: var(--color-subtle);
  font-size: 25rpx;
}

.featured-summary {
  display: -webkit-box;
  overflow: hidden;
  color: var(--color-muted);
  font-size: 24rpx;
  line-height: 1.55;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.featured-footer {
  display: flex;
  min-height: 78rpx;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 4rpx;
  color: var(--color-subtle);
  font-size: 23rpx;
}

.featured-action {
  display: flex;
  min-width: 176rpx;
  min-height: 72rpx;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0 30rpx;
  border-radius: 36rpx;
  background: var(--color-green);
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 720;
  line-height: 1;
}

.featured-action::after {
  border: 0;
}

.compact-events {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 20rpx;
}

.compact-event {
  display: flex;
  min-height: 132rpx;
  align-items: center;
  gap: 18rpx;
  padding: 16rpx;
  border: 2rpx solid var(--color-line);
  border-radius: 26rpx;
  background: #ffffff;
}

.compact-event-cover {
  box-sizing: border-box;
  width: 146rpx;
  height: 104rpx;
  flex: 0 0 auto;
  border-radius: 20rpx;
  background: #edf1ef;
}

.compact-event-placeholder {
  padding: 26rpx;
}

.compact-event-copy {
  display: flex;
  min-width: 0;
  flex: 1;
  flex-direction: column;
  gap: 5rpx;
}

.compact-event-meta {
  color: var(--color-green-dark);
  font-size: 21rpx;
  font-weight: 700;
}

.compact-event-title {
  display: -webkit-box;
  overflow: hidden;
  font-size: 27rpx;
  font-weight: 760;
  line-height: 1.35;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.compact-event-location {
  overflow: hidden;
  color: var(--color-subtle);
  font-size: 21rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.content-heading {
  margin-top: 42rpx;
}

.content-card {
  display: flex;
  min-height: 142rpx;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 16rpx;
  padding: 22rpx;
  border-radius: 28rpx;
}

.content-card-blue {
  background: var(--color-blue-soft);
}

.content-card-purple {
  background: var(--color-purple-soft);
}

.content-card-icon {
  display: flex;
  width: 70rpx;
  height: 70rpx;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.78);
}

.content-card-icon image {
  width: 38rpx;
  height: 38rpx;
}

.content-card-copy {
  display: flex;
  min-width: 0;
  flex: 1;
  flex-direction: column;
  gap: 6rpx;
}

.content-card-label {
  color: var(--color-green-dark);
  font-size: 20rpx;
  font-weight: 700;
}

.content-card-title {
  display: -webkit-box;
  overflow: hidden;
  font-size: 27rpx;
  font-weight: 780;
  line-height: 1.4;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.content-card-summary {
  display: -webkit-box;
  overflow: hidden;
  color: var(--color-muted);
  font-size: 22rpx;
  line-height: 1.45;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
}

.member-strip {
  display: flex;
  min-height: 108rpx;
  align-items: center;
  gap: 18rpx;
  margin-top: 24rpx;
  padding: 20rpx 24rpx;
}

.member-strip-badge {
  width: 70rpx;
  height: 70rpx;
  flex: 0 0 auto;
}

.member-strip-copy {
  display: flex;
  min-width: 0;
  flex: 1;
  flex-direction: column;
  gap: 4rpx;
}

.member-strip-title {
  font-size: 28rpx;
  font-weight: 780;
}

.member-strip-meta {
  overflow: hidden;
  color: var(--color-subtle);
  font-size: 22rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}
