<custom-navigation />
<view class="page-shell home-page">
  <view class="brief-heading">
    <view class="brief-heading-copy">
      <text class="brief-title">现场简报</text>
      <text class="brief-caption">COMMUNITY FIELD NOTES</text>
    </view>
    <text class="brief-date">{{briefDate}}</text>
  </view>

  <view wx:if="{{profileCompletion && !profileCompletion.completed}}" class="profile-progress" bindtap="openProfile" role="button" aria-label="继续完善能力档案">
    <view class="profile-progress-copy">
      <text class="profile-progress-kicker">能力档案 {{profileCompletion.percent}}%</text>
      <text class="profile-progress-title">再补充 {{profileCompletion.missingItems[0]}}，让社区更懂你</text>
    </view>
    <view class="profile-progress-action">继续完善</view>
    <view class="profile-progress-track"><view style="width: {{profileCompletion.percent}}%;"></view></view>
  </view>

  <view wx:if="{{loading}}" class="empty-state">正在整理社区现场记录</view>
  <view wx:elif="{{loadFailed}}" class="empty-state" bindtap="loadPage">现场记录加载失败，轻触重试</view>
  <view wx:elif="{{!featuredEvent}}" class="empty-state">暂时没有可查看的活动记录</view>
  <view wx:else class="feature-record" data-slug="{{featuredEvent.slug}}" bindtap="openEvent">
    <image wx:if="{{featuredEvent.cover_image_url}}" class="feature-cover" src="{{featuredEvent.cover_image_url}}" mode="aspectFill" />
    <view wx:else class="feature-cover feature-cover-placeholder"><image src="/assets/logo-mark.png" mode="aspectFit" /></view>
    <view class="feature-meta">
      <text class="status-tag">{{featuredEvent.statusLabel}}</text>
      <text>{{featuredEvent.eventTypeLabel}}</text>
      <text>{{featuredEvent.dateLabel}}</text>
    </view>
    <view class="feature-copy">
      <text class="feature-index">{{featuredEvent.indexLabel}}</text>
      <view class="feature-body">
        <text class="feature-title">{{featuredEvent.title}}</text>
        <text class="feature-location">{{featuredEvent.locationLabel}}</text>
        <text class="feature-summary">{{featuredEvent.summary || '看看这场活动留下了哪些现场记录。'}}</text>
      </view>
    </view>
    <button class="brief-action" data-slug="{{featuredEvent.slug}}" catchtap="openEvent">查看简报</button>
  </view>

  <block wx:if="{{!loading && !loadFailed && featuredEvent}}">
    <view class="section-heading">
      <text class="section-title">{{eventSectionTitle}}</text>
      <view class="text-action" bindtap="openEvents" role="button" aria-label="{{eventSectionHint}}">{{eventSectionHint}}</view>
    </view>

    <view class="event-list">
    <view
      wx:for="{{events}}"
      wx:key="id"
      class="event-row"
      data-slug="{{item.slug}}"
      bindtap="openEvent"
    >
      <text class="event-index">{{item.indexLabel}}</text>
      <image wx:if="{{item.cover_image_url}}" class="event-cover" src="{{item.cover_image_url}}" mode="{{item.coverMode}}" />
      <image wx:else class="event-cover event-cover-placeholder" src="/assets/logo-mark.png" mode="aspectFit" />
      <view class="event-body">
        <text class="event-meta">{{item.statusLabel}} · {{item.eventTypeLabel}} · {{item.dateLabel}}</text>
        <text class="event-title">{{item.title}}</text>
        <text class="event-location">{{item.locationLabel}}</text>
      </view>
      <image class="event-arrow" src="/assets/icons/chevron-right.png" mode="aspectFit" />
    </view>
    </view>

    <view class="archive-note" bindtap="openEvents">
      <text>社区已发生</text><text class="archive-count">{{eventSectionHint}}</text>
      <image src="/assets/icons/chevron-right.png" mode="aspectFit" />
    </view>
  </block>

  <view wx:if="{{featuredNews || latestDigest}}" class="content-heading">
    <text class="section-title">今日情报</text>
    <view class="text-action" bindtap="openNewsTab" role="button">查看资讯</view>
  </view>
  <view wx:if="{{featuredNews}}" class="content-highlight" data-id="{{featuredNews.id}}" bindtap="openNews">
    <view class="content-highlight-meta"><text>AI HOT</text><text>{{featuredNews.metaLabel}}</text></view>
    <text class="content-highlight-title">{{featuredNews.title}}</text>
    <text wx:if="{{featuredNews.summary}}" class="content-highlight-summary">{{featuredNews.summary}}</text>
  </view>
  <view wx:if="{{latestDigest}}" class="digest-highlight" data-id="{{latestDigest.id}}" bindtap="openDigest">
    <text class="digest-highlight-label">群聊精华 · {{latestDigest.dateLabel}}</text>
    <text class="digest-highlight-title">{{latestDigest.title}}</text>
    <text class="digest-highlight-copy">{{latestDigest.summaryLabel}}</text>
    <image src="/assets/icons/chevron-right.png" mode="aspectFit" />
  </view>
</view>
