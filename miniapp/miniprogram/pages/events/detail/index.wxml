<view class="detail-page">
  <view wx:if="{{loading}}" class="page-shell"><view class="empty-state">正在加载活动</view></view>
  <view wx:elif="{{loadFailed}}" class="page-shell"><view class="empty-state">暂时无法打开这个活动</view></view>
  <block wx:elif="{{event}}">
    <image wx:if="{{event.imageUrl}}" class="detail-cover" src="{{event.imageUrl}}" mode="aspectFill" />
    <view class="page-shell detail-content">
      <view class="detail-header">
        <text class="detail-type">{{event.eventTypeLabel}} · {{event.statusLabel}}</text>
        <text class="detail-title">{{event.title}}</text>
        <text class="detail-summary">{{event.summary}}</text>
      </view>

      <view class="fact-band">
        <view class="fact-row"><text class="fact-label">时间</text><text>{{event.dateTimeLabel}}</text></view>
        <view class="fact-row"><text class="fact-label">地点</text><text>{{event.locationLabel}}</text></view>
      </view>

      <view wx:if="{{event.descriptionParagraphs.length}}" class="detail-section">
        <text class="section-title">活动介绍</text>
        <text wx:for="{{event.descriptionParagraphs}}" wx:key="*this" class="paragraph">{{item}}</text>
      </view>

      <view wx:if="{{event.agendaItems.length}}" class="detail-section">
        <text class="section-title">活动流程</text>
        <view wx:for="{{event.agendaItems}}" wx:key="*this" class="list-row">
          <text class="list-index">{{index + 1}}</text>
          <text class="list-text">{{item}}</text>
        </view>
      </view>

      <view wx:if="{{event.registrationNote}}" class="registration-note">{{event.registrationNote}}</view>
    </view>
  </block>
</view>
