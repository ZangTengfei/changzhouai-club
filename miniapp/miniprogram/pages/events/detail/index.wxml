<view class="detail-page">
  <view wx:if="{{loading}}" class="page-shell"><view class="empty-state">正在加载活动</view></view>
  <view wx:elif="{{loadFailed}}" class="page-shell"><view class="empty-state">暂时无法打开这个活动</view></view>
  <block wx:elif="{{event}}">
    <image wx:if="{{event.imageUrl}}" class="detail-cover" src="{{event.imageUrl}}" mode="aspectFill" />
    <view class="page-shell detail-content">
      <view class="detail-header">
        <text class="detail-type">{{event.eventTypeLabel}} · {{event.statusLabel}}</text>
        <text class="detail-title">{{event.title}}</text>
        <text class="detail-summary">{{event.summary}}</text>
      </view>

      <view class="fact-band">
        <view class="fact-row"><text class="fact-label">时间</text><text>{{event.dateTimeLabel}}</text></view>
        <view class="fact-row"><text class="fact-label">地点</text><text>{{event.locationLabel}}</text></view>
      </view>

      <view wx:if="{{event.descriptionParagraphs.length}}" class="detail-section">
        <text class="section-title">活动介绍</text>
        <text wx:for="{{event.descriptionParagraphs}}" wx:key="*this" class="paragraph">{{item}}</text>
      </view>

      <view wx:if="{{event.agendaItems.length}}" class="detail-section">
        <text class="section-title">活动流程</text>
        <view wx:for="{{event.agendaItems}}" wx:key="*this" class="list-row">
          <text class="list-index">{{index + 1}}</text>
          <text class="list-text">{{item}}</text>
        </view>
      </view>

      <view wx:if="{{event.registrationNote}}" class="registration-note">{{event.registrationNote}}</view>

      <view class="share-row">
        <button class="secondary-button share-button" open-type="share">分享活动</button>
      </view>

      <view wx:if="{{event.status === 'scheduled'}}" class="registration-panel">
        <block wx:if="{{event.registrationUrl}}">
          <text class="registration-title">外部活动报名</text>
          <text class="muted registration-copy">该活动使用外部报名入口，复制链接后在浏览器打开。</text>
          <button class="primary-button" bindtap="copyExternalLink">复制报名链接</button>
        </block>
        <block wx:elif="{{registrationLoading}}">
          <text class="muted">正在检查报名状态</text>
        </block>
        <block wx:elif="{{registration && registration.status === 'registered'}}">
          <text class="registration-title">你已报名</text>
          <text class="muted registration-copy">活动开始前可以在“我的活动”中再次查看。</text>
          <button wx:if="{{reminder && reminder.available && (!reminder.subscription || reminder.subscription.status !== 'accepted')}}" class="primary-button" loading="{{reminderSubmitting}}" disabled="{{reminderSubmitting}}" bindtap="enableReminder">开启活动提醒</button>
          <view wx:elif="{{reminder && reminder.subscription && reminder.subscription.status === 'accepted'}}" class="reminder-status">活动提醒已开启</view>
          <button class="secondary-button" loading="{{submitting}}" disabled="{{submitting}}" bindtap="cancelRegistration">取消报名</button>
        </block>
        <block wx:elif="{{!user || !user.profileComplete}}">
          <text class="registration-title">完善资料后报名</text>
          <text class="muted registration-copy">昵称和微信号用于活动联系，只需填写一次。</text>
          <button class="primary-button" bindtap="openProfile">完善社区资料</button>
        </block>
        <block wx:else>
          <text class="registration-title">报名这场活动</text>
          <textarea class="registration-textarea" maxlength="500" value="{{registrationNote}}" bindinput="handleNoteInput" placeholder="可选：写下你特别想交流的话题" />
          <button class="primary-button" loading="{{submitting}}" disabled="{{submitting}}" bindtap="submitRegistration">确认报名</button>
        </block>
      </view>
    </view>
  </block>
</view>
