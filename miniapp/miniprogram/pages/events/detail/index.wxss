.detail-page {
  min-height: 100vh;
}

.detail-cover {
  display: block;
  width: 100%;
  height: 500rpx;
  border-bottom: 8rpx solid var(--color-orange);
  background: #e6e9e7;
}

.detail-content {
  padding-top: 0;
}

.detail-header {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding: 38rpx 0 36rpx;
}

.detail-title {
  font-size: 46rpx;
  font-weight: 760;
  line-height: 1.3;
}

.detail-summary {
  color: var(--color-muted);
  font-size: 28rpx;
  line-height: 1.7;
}

.fact-band {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin: 0 0 56rpx;
  border-top: 2rpx solid var(--color-ink);
  border-bottom: 2rpx solid var(--color-ink);
  background: var(--color-surface);
}

.fact-row {
  display: flex;
  min-width: 0;
  flex-direction: column;
  gap: 10rpx;
  padding: 24rpx 18rpx 26rpx 0;
}

.fact-row + .fact-row {
  padding-left: 22rpx;
  border-left: 2rpx solid var(--color-line);
}

.fact-label {
  color: var(--color-green);
  font-size: 19rpx;
  font-weight: 760;
}

.fact-value {
  color: var(--color-ink);
  font-size: 25rpx;
  line-height: 1.5;
}

.detail-section {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  margin-top: 52rpx;
  padding-top: 28rpx;
  border-top: 2rpx solid var(--color-line);
}

.recap-section {
  margin-top: 0;
}

.detail-section-heading,
.record-heading {
  display: flex;
  align-items: center;
}

.detail-section-heading {
  justify-content: space-between;
}

.record-heading {
  gap: 16rpx;
}

.record-number {
  display: flex;
  width: 48rpx;
  height: 48rpx;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  border-radius: 6rpx;
  background: var(--color-green);
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 760;
}

.record-number-blue {
  background: var(--color-blue);
}

.record-number-orange {
  background: var(--color-orange);
}

.section-count {
  color: var(--color-subtle);
  font-size: 24rpx;
}

.event-video {
  width: 100%;
  height: 380rpx;
  border-radius: 6rpx;
  background: var(--color-ink);
}

.gallery-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.gallery-image {
  width: 100%;
  height: 224rpx;
  border-radius: 4rpx;
  background: #e6e9e7;
}

.paragraph {
  color: #35413b;
  font-size: 28rpx;
  line-height: 1.8;
}

.list-row {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 2rpx solid var(--color-line);
}

.list-index {
  width: 42rpx;
  flex: 0 0 auto;
  color: var(--color-orange);
  font-size: 24rpx;
  font-weight: 760;
}

.list-text {
  min-width: 0;
  flex: 1;
  font-size: 28rpx;
  line-height: 1.6;
}

.registration-note {
  margin-top: 48rpx;
  padding: 26rpx 28rpx;
  border-left: 8rpx solid var(--color-orange);
  background: var(--color-orange-soft);
  color: #603225;
  font-size: 27rpx;
  line-height: 1.7;
}

.share-row {
  margin-top: 24rpx;
}

.resource-button {
  margin-top: 40rpx;
}

.completed-panel,
.registration-panel {
  margin-top: 40rpx;
  border-top: 2rpx solid var(--color-ink);
}

.completed-note {
  padding: 24rpx 0;
  color: var(--color-subtle);
  font-size: 25rpx;
  line-height: 1.6;
}

.feedback-panel,
.registration-panel {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding-top: 28rpx;
}

.feedback-panel {
  border-top: 2rpx solid var(--color-line);
}

.feedback-heading,
.rating-caption {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.feedback-status,
.rating-caption {
  color: var(--color-subtle);
  font-size: 22rpx;
}

.rating-switch {
  display: grid;
  height: 76rpx;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  padding: 6rpx;
  border: 2rpx solid var(--color-line);
  border-radius: 8rpx;
  background: #edf1ef;
}

.rating-option {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 6rpx;
  color: var(--color-muted);
  font-size: 27rpx;
  font-weight: 680;
}

.rating-option-active {
  background: var(--color-green);
  color: #ffffff;
}

.share-button {
  width: 100%;
}

.registration-title {
  font-size: 32rpx;
  font-weight: 700;
}

.registration-copy {
  font-size: 25rpx;
  line-height: 1.6;
}

.reminder-status {
  padding: 20rpx 24rpx;
  border-left: 8rpx solid var(--color-green);
  background: var(--color-green-soft);
  color: var(--color-green-dark);
  font-size: 26rpx;
}

.registration-textarea {
  box-sizing: border-box;
  width: 100%;
  min-height: 180rpx;
  padding: 22rpx 24rpx;
  border: 2rpx solid #cbd3cf;
  border-radius: 8rpx;
  background: var(--color-surface);
  font-size: 27rpx;
  line-height: 1.6;
}
