.events-page {
  padding-top: 20rpx;
}

.index-brand {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 14rpx 0 28rpx;
}

.index-brand image {
  width: 62rpx;
  height: 62rpx;
}

.index-brand text {
  font-size: 34rpx;
  font-weight: 800;
}

.page-heading {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 26rpx 0 28rpx;
  border-top: 2rpx solid var(--color-line);
  border-bottom: 2rpx solid var(--color-line);
}

.page-title-row {
  display: flex;
  align-items: baseline;
  gap: 20rpx;
}

.page-title {
  font-size: 52rpx;
  font-weight: 820;
  line-height: 1.15;
}

.record-count {
  color: var(--color-green);
  font-size: 27rpx;
  font-weight: 760;
}

.page-summary {
  color: var(--color-muted);
  font-size: 24rpx;
  line-height: 1.55;
}

.mode-tabs,
.category-tabs {
  display: flex;
  align-items: center;
}

.mode-tabs {
  gap: 30rpx;
  min-height: 78rpx;
  border-bottom: 2rpx solid var(--color-line);
}

.mode-tab {
  display: flex;
  align-items: center;
  align-self: stretch;
  gap: 10rpx;
  padding: 0 4rpx;
  border-bottom: 6rpx solid transparent;
  color: var(--color-subtle);
  font-size: 25rpx;
  font-weight: 680;
}

.mode-tab-active {
  border-bottom-color: var(--color-green);
  color: var(--color-ink);
}

.category-tabs {
  gap: 28rpx;
  min-height: 86rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.category-tab {
  padding: 12rpx 0;
  color: var(--color-subtle);
  font-size: 24rpx;
  font-weight: 650;
}

.category-tab-active {
  color: var(--color-green);
  font-weight: 760;
}

.category-tab-external-active {
  color: var(--color-blue);
}

.event-index {
  border-top: 2rpx solid var(--color-line);
}

.month-group + .month-group {
  border-top: 2rpx solid var(--color-line);
}

.month-heading {
  display: flex;
  align-items: flex-end;
  gap: 22rpx;
  padding: 34rpx 0 20rpx;
}

.month-copy {
  display: flex;
  width: 112rpx;
  flex: 0 0 auto;
  flex-direction: column;
  gap: 2rpx;
}

.month-label {
  color: var(--color-green);
  font-size: 46rpx;
  font-weight: 820;
  line-height: 1;
}

.year-label,
.month-count {
  color: var(--color-subtle);
  font-size: 21rpx;
}

.month-count {
  padding-bottom: 2rpx;
}

.month-events {
  border-top: 2rpx solid var(--color-line);
}

.event-row {
  display: grid;
  grid-template-columns: 112rpx 160rpx minmax(0, 1fr) 28rpx;
  align-items: center;
  gap: 14rpx;
  min-height: 170rpx;
  padding: 24rpx 0;
  border-bottom: 2rpx solid var(--color-line);
}

.event-date {
  display: flex;
  align-self: stretch;
  flex-direction: column;
  justify-content: center;
  gap: 7rpx;
  padding-right: 14rpx;
  border-right: 2rpx solid var(--color-line);
}

.event-day {
  color: var(--color-green);
  font-size: 23rpx;
  font-weight: 760;
}

.event-time {
  color: var(--color-subtle);
  font-size: 20rpx;
  line-height: 1.35;
}

.event-image {
  width: 160rpx;
  height: 116rpx;
  border-radius: 6rpx;
  background: #e8edeb;
}

.event-image-placeholder {
  box-sizing: border-box;
  padding: 28rpx;
}

.event-content {
  display: flex;
  min-width: 0;
  flex-direction: column;
  gap: 8rpx;
}

.event-type {
  color: var(--color-green);
  font-size: 21rpx;
  font-weight: 700;
}

.event-type-external {
  color: var(--color-blue);
}

.event-name {
  display: -webkit-box;
  overflow: hidden;
  font-size: 27rpx;
  font-weight: 760;
  line-height: 1.35;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.event-location {
  overflow: hidden;
  color: var(--color-subtle);
  font-size: 20rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.event-arrow {
  width: 28rpx;
  height: 28rpx;
}
