.page-heading {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-bottom: 36rpx;
}

.page-summary {
  color: #59635f;
  font-size: 26rpx;
  line-height: 1.6;
}

.event-grid {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.event-item {
  overflow: hidden;
  border: 2rpx solid #dce2df;
  border-radius: 8rpx;
  background: #ffffff;
}

.event-image {
  display: block;
  width: 100%;
  height: 320rpx;
  background: #e5eae7;
}

.event-content {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding: 28rpx;
}

.event-type {
  color: #147a5b;
  font-size: 23rpx;
  font-weight: 650;
}

.event-name {
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.4;
}

.event-summary {
  display: -webkit-box;
  overflow: hidden;
  color: #59635f;
  font-size: 26rpx;
  line-height: 1.6;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.event-facts {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx 24rpx;
  padding-top: 8rpx;
  color: #68716d;
  font-size: 24rpx;
}
