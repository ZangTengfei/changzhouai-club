.events-page {
  padding-top: 22rpx;
}

.chip-row {
  margin-bottom: 20rpx;
}

.month-group {
  margin-top: 8rpx;
}

.month-heading {
  margin-top: 36rpx;
}

.month-copy {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.month-label {
  font-size: 42rpx;
  font-weight: 820;
}

.year-label,
.month-count {
  color: var(--color-subtle);
  font-size: 23rpx;
}

.month-events {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.event-card {
  overflow: hidden;
}

.event-media {
  position: relative;
  display: flex;
  width: 100%;
  height: 330rpx;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: #eef2f0;
}

.event-image {
  width: 100%;
  height: 100%;
}

.event-image-placeholder image {
  width: 126rpx;
  height: 126rpx;
}

.event-date-tile {
  position: absolute;
  top: 18rpx;
  left: 18rpx;
  display: flex;
  min-width: 106rpx;
  min-height: 94rpx;
  box-sizing: border-box;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
  padding: 10rpx 14rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.94);
  color: var(--color-orange);
  box-shadow: 0 10rpx 22rpx rgba(41, 50, 46, 0.12);
}

.event-date-tile text:first-child {
  font-size: 27rpx;
  font-weight: 800;
}

.event-date-tile text:last-child {
  font-size: 18rpx;
  font-weight: 650;
}

.event-content {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 28rpx;
}

.event-type {
  width: fit-content;
  padding: 5rpx 14rpx;
  border-radius: 18rpx;
  background: var(--color-orange-soft);
  color: var(--color-orange);
  font-size: 21rpx;
  font-weight: 720;
}

.event-type-external {
  background: var(--color-blue-soft);
  color: var(--color-blue);
}

.event-name {
  display: -webkit-box;
  overflow: hidden;
  font-size: 34rpx;
  font-weight: 820;
  line-height: 1.35;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.event-footer {
  display: flex;
  min-height: 54rpx;
  align-items: center;
  gap: 12rpx;
  color: var(--color-subtle);
  font-size: 23rpx;
}

.event-location {
  overflow: hidden;
  flex: 1;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.event-status {
  color: var(--color-green-dark);
  font-weight: 700;
}

.history-teaser {
  display: flex;
  min-height: 126rpx;
  align-items: center;
  gap: 18rpx;
  margin-top: 28rpx;
  padding: 22rpx;
  border: 2rpx solid #e3ddff;
  border-radius: 28rpx;
  background: var(--color-purple-soft);
}

.history-copy {
  display: flex;
  min-width: 0;
  flex: 1;
  flex-direction: column;
  gap: 6rpx;
}

.history-copy text:first-child {
  font-size: 28rpx;
  font-weight: 780;
}

.history-copy text:last-child {
  color: var(--color-subtle);
  font-size: 22rpx;
}
