page {
  min-height: 100%;
  background: #f5f7f6;
  color: #17211d;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  font-size: 30rpx;
}

button {
  letter-spacing: 0;
}

.page-shell {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 32rpx 28rpx 64rpx;
}

.section-title {
  margin: 0;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.3;
}

.muted {
  color: #68716d;
}

.primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  margin: 0;
  border-radius: 8rpx;
  background: #147a5b;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 650;
}

.primary-button::after {
  border: 0;
}

.secondary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 80rpx;
  margin: 0;
  border: 2rpx solid #cbd3cf;
  border-radius: 8rpx;
  background: #ffffff;
  color: #27332e;
  font-size: 28rpx;
}

.secondary-button::after {
  border: 0;
}

.empty-state {
  padding: 64rpx 32rpx;
  border: 2rpx dashed #cbd3cf;
  border-radius: 8rpx;
  color: #68716d;
  text-align: center;
}
