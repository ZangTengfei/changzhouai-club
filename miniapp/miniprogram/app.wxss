page {
  --color-canvas: #ffffff;
  --color-surface: #ffffff;
  --color-ink: #111715;
  --color-muted: #5e6864;
  --color-subtle: #737d79;
  --color-line: #e8eeeb;
  --color-green: #12a566;
  --color-green-dark: #08794a;
  --color-green-soft: #e9f9f0;
  --color-orange: #f47b20;
  --color-orange-soft: #fff2e5;
  --color-blue: #2f80ed;
  --color-blue-soft: #edf5ff;
  --color-purple: #7357e8;
  --color-purple-soft: #f3efff;
  --color-yellow: #e3a812;
  --color-yellow-soft: #fff8dd;
  --radius-card: 32rpx;
  --radius-control: 22rpx;
  --shadow-card: 0 14rpx 36rpx rgba(28, 55, 44, 0.08);
  min-height: 100%;
  background: var(--color-canvas);
  color: var(--color-ink);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: 30rpx;
}

button {
  letter-spacing: 0;
}

text,
view,
input,
textarea {
  letter-spacing: 0;
}

.page-shell {
  box-sizing: border-box;
  min-height: 100%;
  padding: 28rpx 32rpx 64rpx;
}

.section-title {
  margin: 0;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.25;
}

.muted {
  color: var(--color-subtle);
}

.primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 92rpx;
  margin: 0;
  border-radius: 46rpx;
  background: var(--color-green);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 12rpx 24rpx rgba(18, 165, 102, 0.18);
}

.primary-button::after {
  border: 0;
}

.secondary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  margin: 0;
  border: 2rpx solid var(--color-line);
  border-radius: 44rpx;
  background: var(--color-surface);
  color: var(--color-ink);
  font-size: 28rpx;
  font-weight: 650;
}

.secondary-button::after {
  border: 0;
}

.empty-state {
  padding: 44rpx 32rpx;
  border: 2rpx solid #dfeee7;
  border-radius: var(--radius-card);
  background: var(--color-green-soft);
  color: var(--color-subtle);
  font-size: 27rpx;
  line-height: 1.6;
  text-align: left;
}

.status-tag {
  display: inline-flex;
  width: fit-content;
  align-items: center;
  min-height: 42rpx;
  padding: 4rpx 14rpx;
  border-radius: 21rpx;
  background: var(--color-green-soft);
  color: var(--color-green-dark);
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.4;
}

.status-tag-blue {
  background: var(--color-blue-soft);
  color: var(--color-blue);
}

.surface-card {
  box-sizing: border-box;
  border: 2rpx solid rgba(17, 23, 21, 0.04);
  border-radius: var(--radius-card);
  background: var(--color-surface);
  box-shadow: var(--shadow-card);
}

.tone-green {
  background: var(--color-green-soft);
}

.tone-blue {
  background: var(--color-blue-soft);
}

.tone-orange {
  background: var(--color-orange-soft);
}

.tone-purple {
  background: var(--color-purple-soft);
}

.tone-yellow {
  background: var(--color-yellow-soft);
}

.section-heading-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 48rpx;
  margin-bottom: 22rpx;
}

.section-action {
  display: flex;
  min-height: 72rpx;
  align-items: center;
  color: var(--color-subtle);
  font-size: 25rpx;
  white-space: nowrap;
}

.page-intro {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 28rpx;
}

.page-intro-title {
  font-size: 50rpx;
  font-weight: 820;
  line-height: 1.2;
}

.page-intro-copy {
  color: var(--color-subtle);
  font-size: 27rpx;
  line-height: 1.55;
}

.segmented-control {
  display: flex;
  box-sizing: border-box;
  gap: 6rpx;
  padding: 8rpx;
  border: 2rpx solid var(--color-line);
  border-radius: 46rpx;
  background: #ffffff;
}

.segmented-item {
  display: flex;
  min-height: 74rpx;
  flex: 1;
  align-items: center;
  justify-content: center;
  border-radius: 38rpx;
  color: var(--color-muted);
  font-size: 27rpx;
  font-weight: 650;
}

.segmented-item-active {
  background: var(--color-green);
  color: #ffffff;
  font-weight: 720;
}

.chip-row {
  display: flex;
  gap: 14rpx;
  padding: 22rpx 0 8rpx;
  white-space: nowrap;
}

.filter-chip {
  display: inline-flex;
  min-height: 64rpx;
  align-items: center;
  justify-content: center;
  padding: 0 24rpx;
  border: 2rpx solid var(--color-line);
  border-radius: 32rpx;
  background: #ffffff;
  color: var(--color-muted);
  font-size: 24rpx;
}

.filter-chip-active {
  border-color: #bdebd3;
  background: var(--color-green-soft);
  color: var(--color-green-dark);
  font-weight: 700;
}

.icon-tile {
  display: flex;
  width: 76rpx;
  height: 76rpx;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.72);
}

.icon-tile image {
  width: 42rpx;
  height: 42rpx;
}

.row-arrow {
  width: 28rpx;
  height: 28rpx;
  flex: 0 0 auto;
  opacity: 0.7;
}
